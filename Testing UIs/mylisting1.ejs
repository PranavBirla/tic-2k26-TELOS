<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KRISHIQ | My Listings</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; }

    :root {
      --emerald:  #059669;
      --emerald-dark: #047857;
      --slate-bg: #F0F4F8;
      --text-primary: #0F172A;
      --text-secondary: #475569;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background-color: #F0F4F8;
      color: var(--text-primary);
    }

    /* ── NAV ── */
    .nav-glass {
      background: rgba(255,255,255,0.82);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
    }

    /* ── HERO ── */
    .hero-img-overlay {
      background: linear-gradient(
        160deg,
        rgba(2,44,24,0.72) 0%,
        rgba(5,150,105,0.38) 55%,
        rgba(0,0,0,0.55) 100%
      );
    }

    /* ── GLASS BADGE ── */
    .glass {
      background: rgba(255,255,255,0.14);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.28);
    }

    /* ── STAT CARDS OVERLAP ── */
    .stats-overlap {
      margin-top: -56px;
      position: relative;
      z-index: 20;
    }

    /* ── CROP CARD ── */
    .crop-card {
      transition: transform 0.32s cubic-bezier(.22,1,.36,1), box-shadow 0.32s ease;
      will-change: transform;
    }
    .crop-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 28px 60px rgba(5,150,105,0.14), 0 8px 24px rgba(15,23,42,0.10);
    }
    .crop-card:hover .crop-img-inner {
      transform: scale(1.06);
    }
    .crop-img-inner {
      transition: transform 0.42s cubic-bezier(.22,1,.36,1);
    }

    /* ── ACTION STRIP ── */
    .action-strip { transition: opacity 0.2s ease; }
    .action-btn-icon {
      transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
    }
    .action-btn-icon:hover { transform: scale(1.12); }

    /* ── INSIGHT CARD ── */
    .insight-card {
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .insight-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 16px 40px rgba(5,150,105,0.12), 0 4px 16px rgba(15,23,42,0.08);
    }

    /* ── PULSE DOT ── */
    .pulse-dot {
      position: relative;
    }
    .pulse-dot::after {
      content: '';
      position: absolute;
      inset: -3px;
      border-radius: 50%;
      background: rgba(16,185,129,0.35);
      animation: pulseRing 1.8s ease-out infinite;
    }
    @keyframes pulseRing {
      0%   { transform: scale(0.9); opacity: 1; }
      100% { transform: scale(1.8); opacity: 0; }
    }

    /* ── STAGGERED CARD ENTRY ── */
    @keyframes cardIn {
      from { opacity: 0; transform: translateY(28px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .crop-card { animation: cardIn 0.48s cubic-bezier(.22,1,.36,1) both; }
    .crop-card:nth-child(1) { animation-delay: 0.05s; }
    .crop-card:nth-child(2) { animation-delay: 0.12s; }
    .crop-card:nth-child(3) { animation-delay: 0.19s; }
    .crop-card:nth-child(4) { animation-delay: 0.26s; }
    .crop-card:nth-child(5) { animation-delay: 0.33s; }
    .crop-card:nth-child(6) { animation-delay: 0.40s; }
    .crop-card:nth-child(n+7) { animation-delay: 0.46s; }

    /* ── HERO TEXT REVEAL ── */
    @keyframes heroIn {
      from { opacity: 0; transform: translateY(22px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .hero-headline { animation: heroIn 0.7s 0.15s cubic-bezier(.22,1,.36,1) both; }
    .hero-sub      { animation: heroIn 0.7s 0.30s cubic-bezier(.22,1,.36,1) both; }
    .hero-badge    { animation: heroIn 0.7s 0.45s cubic-bezier(.22,1,.36,1) both; }

    /* ── GRADIENT BORDER ON ACTIVE STAT ── */
    .stat-accent {
      border-top: 3px solid transparent;
      background-clip: padding-box;
      position: relative;
    }
    .stat-accent::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: inherit;
      padding: 0;
      pointer-events: none;
    }
    .stat-emerald::before { border-top: 3px solid #059669; }
    .stat-blue::before    { border-top: 3px solid #3b82f6; }
    .stat-amber::before   { border-top: 3px solid #f59e0b; }

    /* ── LOW STOCK SHIMMER ── */
    @keyframes shimmer {
      0%   { background-position: -200% center; }
      100% { background-position: 200% center; }
    }
    .low-stock-badge {
      background: linear-gradient(90deg, #fbbf24 25%, #fef3c7 50%, #fbbf24 75%);
      background-size: 200% auto;
      animation: shimmer 2.4s linear infinite;
    }

    /* ── SCROLLBAR ── */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 9999px; }

    /* ── EMPTY STATE ── */
    @keyframes floatUp {
      0%, 100% { transform: translateY(0); }
      50%       { transform: translateY(-10px); }
    }
    .float-anim { animation: floatUp 3.5s ease-in-out infinite; }
  </style>
</head>

<body class="antialiased min-h-screen">

  <!-- ══════════════════════════════════════════
       NAVIGATION
  ══════════════════════════════════════════ -->
  <nav class="nav-glass sticky top-0 z-50 border-b border-slate-100/80">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 py-3.5 flex items-center justify-between gap-4">

      <!-- Brand -->
      <div class="flex items-center gap-2.5">
        <div class="w-8 h-8 bg-emerald-600 rounded-lg flex items-center justify-center shadow-md shadow-emerald-200 flex-shrink-0">
          <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17 8C8 10 5.9 16.17 3.82 19c-1.8 2.5-1.52 3-1.52 3H5c1.5-3 6-8 14-8-3 .5-6 2-8 4 2-3 8-5 12-5-5 2-8 6-8 6h3c4-5 10-7 10-7s-6.5 1.5-9 5z"/>
          </svg>
        </div>
        <span class="text-2xl font-black text-emerald-700 tracking-tight">KRISHIQ</span>
      </div>

      <!-- Right Actions -->
      <div class="flex items-center gap-3">
        <a href="/addcrop"
          class="hidden sm:flex items-center gap-2 bg-emerald-600 text-white text-sm font-semibold px-5 py-2.5 rounded-full hover:bg-emerald-700 transition-all duration-200 shadow-md shadow-emerald-200/60 hover:shadow-lg hover:shadow-emerald-300/50 hover:-translate-y-0.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
          </svg>
          Add Crop
        </a>
        <!-- Mobile Add -->
        <a href="/addcrop"
          class="sm:hidden w-9 h-9 bg-emerald-600 text-white rounded-full flex items-center justify-center shadow-md">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
          </svg>
        </a>

        <!-- Profile Avatar -->
        <div class="w-9 h-9 rounded-full border-2 border-slate-200 bg-slate-50 flex items-center justify-center cursor-pointer hover:border-emerald-400 transition-colors duration-200 overflow-hidden">
          <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </div>
      </div>
    </div>
  </nav>


  <!-- ══════════════════════════════════════════
       HERO SECTION
  ══════════════════════════════════════════ -->
  <section class="relative h-[440px] sm:h-[480px] overflow-hidden">

    <!-- Background Image -->
    <img
      src="https://images.unsplash.com/photo-1625246333195-78d9c38ad449?auto=format&fit=crop&w=1800&q=80"
      alt="Farm background"
      class="absolute inset-0 w-full h-full object-cover object-center"
    />

    <!-- Dark gradient overlay -->
    <div class="hero-img-overlay absolute inset-0"></div>

    <!-- Decorative grid lines overlay -->
    <div class="absolute inset-0 opacity-[0.06]"
      style="background-image: repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(255,255,255,1) 39px, rgba(255,255,255,1) 40px), repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(255,255,255,1) 39px, rgba(255,255,255,1) 40px);">
    </div>

    <!-- Hero Content -->
    <div class="relative z-10 h-full flex flex-col items-center justify-center text-center px-5 pb-16">

      <!-- Tag -->
      <div class="hero-headline mb-5 inline-flex items-center gap-2 glass rounded-full px-4 py-1.5 text-emerald-300 text-xs font-semibold tracking-widest uppercase">
        <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full pulse-dot relative"></span>
        Live Marketplace
      </div>

      <h1 class="hero-headline text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-[1.12] tracking-tight max-w-3xl">
        Empowering<br/>
        <span class="text-emerald-400">Indian Farmers</span>
      </h1>

      <p class="hero-sub mt-4 text-slate-300 text-sm sm:text-base max-w-xl leading-relaxed">
        Manage your harvest, set your price, and connect with buyers across the country — all in one place.
      </p>

      <!-- Glassmorphic Listing Badge -->
      <div class="hero-badge absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 z-30">
        <div class="glass rounded-2xl px-7 py-4 flex items-center gap-4 shadow-2xl">
          <div class="w-11 h-11 rounded-xl bg-emerald-500/30 border border-emerald-400/40 flex items-center justify-center">
            <svg class="w-5 h-5 text-emerald-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
          </div>
          <div class="text-left">
            <p class="text-white/60 text-xs font-medium">My Listings</p>
            <p class="text-white text-2xl font-black leading-none">
              <%= crops.length %> <span class="text-sm font-medium text-white/70">Crops Active</span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════
       STATS OVERLAP ROW
  ══════════════════════════════════════════ -->
  <div class="max-w-7xl mx-auto px-5 sm:px-8 stats-overlap">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-5 mt-10 sm:mt-0">

      <!-- Total Listings -->
      <div class="insight-card stat-accent stat-emerald bg-white rounded-2xl p-5 sm:p-6 shadow-xl shadow-slate-200/80 border border-slate-50 flex items-center gap-4 overflow-hidden relative">
        <div class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 7h18M3 12h18M3 17h18"/>
          </svg>
        </div>
        <div>
          <p class="text-3xl font-black text-slate-800"><%= crops.length %></p>
          <p class="text-xs text-slate-400 font-medium mt-0.5">Total Listings</p>
        </div>
        <svg class="absolute -right-2 -bottom-2 w-20 h-20 text-emerald-500 opacity-[0.07]" fill="currentColor" viewBox="0 0 24 24">
          <path d="M3 7h18M3 12h18M3 17h18"/>
        </svg>
      </div>

      <!-- Total Inquiries -->
      <div class="insight-card stat-accent stat-blue bg-white rounded-2xl p-5 sm:p-6 shadow-xl shadow-slate-200/80 border border-slate-50 flex items-center gap-4 overflow-hidden relative">
        <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87M12 11a4 4 0 110-8 4 4 0 010 8z"/>
          </svg>
        </div>
        <div>
          <p class="text-3xl font-black text-slate-800"><%= crops.reduce((s,c)=>s+c.buyers,0) %></p>
          <p class="text-xs text-slate-400 font-medium mt-0.5">Total Inquiries</p>
        </div>
        <svg class="absolute -right-2 -bottom-2 w-20 h-20 text-blue-500 opacity-[0.07]" fill="currentColor" viewBox="0 0 24 24">
          <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
        </svg>
      </div>

      <!-- Estimated Value -->
      <div class="insight-card stat-accent stat-amber bg-white rounded-2xl p-5 sm:p-6 shadow-xl shadow-slate-200/80 border border-slate-50 flex items-center gap-4 overflow-hidden relative">
        <div class="w-12 h-12 rounded-xl bg-amber-50 flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-amber-500" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <line x1="12" y1="1" x2="12" y2="23"/>
            <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
          </svg>
        </div>
        <div>
          <p class="text-2xl font-black text-slate-800">
            ₹<%= crops.reduce((s,c)=>s+(c.price*c.quantity),0).toLocaleString('en-IN') %>
          </p>
          <p class="text-xs text-slate-400 font-medium mt-0.5">Estimated Value</p>
        </div>
        <svg class="absolute -right-2 -bottom-2 w-20 h-20 text-amber-500 opacity-[0.07]" fill="currentColor" viewBox="0 0 24 24">
          <path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/>
        </svg>
      </div>

    </div>
  </div>


  <!-- ══════════════════════════════════════════
       MAIN CONTENT
  ══════════════════════════════════════════ -->
  <main class="max-w-7xl mx-auto px-5 sm:px-8 py-12">

    <!-- Section Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-xl sm:text-2xl font-extrabold text-slate-800 tracking-tight">My Crop Listings</h2>
        <p class="text-slate-400 text-sm mt-1">Your active produce on the marketplace</p>
      </div>
      <!-- Filter pill (visual only) -->
      <div class="hidden sm:flex items-center gap-2">
        <span class="px-3 py-1 rounded-full bg-emerald-600 text-white text-xs font-semibold cursor-pointer">All</span>
        <span class="px-3 py-1 rounded-full bg-white border border-slate-200 text-slate-500 text-xs font-semibold cursor-pointer hover:border-emerald-300 transition-colors">Active</span>
        <span class="px-3 py-1 rounded-full bg-white border border-slate-200 text-slate-500 text-xs font-semibold cursor-pointer hover:border-emerald-300 transition-colors">Sold</span>
      </div>
    </div>


    <!-- ────────────────────────────────────────
         EMPTY STATE
    ──────────────────────────────────────── -->
    <% if (crops.length === 0) { %>
    <div class="flex flex-col items-center justify-center py-24 px-6 text-center">
      <div class="float-anim mb-8">
        <svg viewBox="0 0 220 220" class="w-48 h-48 sm:w-56 sm:h-56" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="110" cy="110" r="90" fill="#d1fae5" opacity="0.5"/>
          <circle cx="110" cy="110" r="65" fill="#a7f3d0" opacity="0.4"/>
          <!-- Pot -->
          <rect x="80" y="160" width="60" height="28" rx="8" fill="#6ee7b7"/>
          <rect x="75" y="155" width="70" height="12" rx="6" fill="#34d399"/>
          <!-- Stem -->
          <path d="M110 155 Q110 130 110 115" stroke="#10b981" stroke-width="4" stroke-linecap="round"/>
          <!-- Left leaf -->
          <path d="M110 135 Q85 120 72 100 Q95 96 108 118Z" fill="#059669"/>
          <!-- Right leaf -->
          <path d="M110 122 Q135 108 148 88 Q125 84 112 106Z" fill="#10b981"/>
          <!-- Top leaf -->
          <ellipse cx="110" cy="100" rx="20" ry="14" fill="#34d399" transform="rotate(-10,110,100)"/>
          <!-- Sparkles -->
          <circle cx="62" cy="80" r="4" fill="#fbbf24" opacity="0.8"/>
          <circle cx="158" cy="72" r="3" fill="#6ee7b7" opacity="0.9"/>
          <circle cx="70" cy="148" r="2.5" fill="#059669" opacity="0.6"/>
          <circle cx="152" cy="150" r="3.5" fill="#fbbf24" opacity="0.7"/>
        </svg>
      </div>
      <h3 class="text-2xl font-extrabold text-slate-800 mb-3">No crops listed yet</h3>
      <p class="text-slate-400 text-sm max-w-sm mb-8 leading-relaxed">
        Your field is empty — but full of potential. Add your first crop to start reaching thousands of buyers.
      </p>
      <a href="/addcrop"
        class="inline-flex items-center gap-2.5 bg-emerald-600 text-white text-sm font-bold px-7 py-3.5 rounded-full hover:bg-emerald-700 transition-all duration-200 shadow-lg shadow-emerald-300/50 hover:shadow-xl hover:shadow-emerald-300/60 hover:-translate-y-0.5">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
        </svg>
        Add Your First Crop
      </a>
    </div>
    <% } %>


    <!-- ────────────────────────────────────────
         CROP GRID
    ──────────────────────────────────────── -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5 sm:gap-6">

      <% crops.forEach(function(crop) { %>
      <%
        var isSold    = crop.status === 'sold' || crop.quantity === 0;
        var isLow     = !isSold && crop.quantity > 0 && crop.quantity < 50;
      %>

      <div class="crop-card group bg-white rounded-2xl border border-slate-100 shadow-md shadow-slate-200/60 overflow-hidden flex flex-col <%= isSold ? 'opacity-60' : '' %>">

        <!-- ── IMAGE CONTAINER ── -->
        <div class="relative h-48 sm:h-52 overflow-hidden bg-slate-100 flex-shrink-0">

          <img
            src="<%= crop.image %>"
            alt="<%= crop.cropName %>"
            class="crop-img-inner w-full h-full object-cover <%= isSold ? 'grayscale' : '' %>"
            onerror="this.src='https://images.unsplash.com/photo-1574943320219-553eb213f72d?auto=format&fit=crop&w=800&q=70'"
          />

          <!-- Gradient fade at bottom of image -->
          <div class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-black/40 to-transparent"></div>

          <!-- Status Badge -->
          <div class="absolute top-3 right-3 flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-bold
            <%= isSold
                ? 'bg-slate-700/70 text-slate-200 backdrop-blur-sm'
                : 'bg-emerald-500/20 backdrop-blur-md border border-emerald-400/30 text-emerald-300' %>">
            <span class="w-1.5 h-1.5 rounded-full <%= isSold ? 'bg-slate-400' : 'bg-emerald-400' %>"></span>
            <%= isSold ? 'Sold Out' : 'Active' %>
          </div>

          <!-- Low Stock Badge -->
          <% if (isLow) { %>
          <div class="low-stock-badge absolute top-3 left-3 px-2.5 py-1 rounded-full text-[10px] font-black text-amber-900 tracking-wide uppercase">
            ⚡ Low Stock
          </div>
          <% } %>

          <!-- Price Pill (bottom of image) -->
          <div class="absolute bottom-3 left-3">
            <span class="inline-block bg-white/90 backdrop-blur-sm text-emerald-700 font-extrabold text-sm px-3 py-1 rounded-full shadow-sm">
              ₹<%= crop.price %>/kg
            </span>
          </div>
        </div>


        <!-- ── CARD BODY ── -->
        <div class="p-4 flex flex-col flex-1">

          <!-- Category -->
          <p class="text-[10px] font-bold text-emerald-500 uppercase tracking-widest mb-1.5"><%= crop.category %></p>

          <!-- Crop Name -->
          <h3 class="text-base font-extrabold text-slate-800 leading-snug mb-3 group-hover:text-emerald-700 transition-colors duration-200">
            <%= crop.cropName %>
          </h3>

          <!-- 2-col metadata -->
          <div class="grid grid-cols-2 gap-2 mb-4">
            <div class="bg-slate-50 rounded-xl p-2.5">
              <p class="text-[10px] text-slate-400 font-medium mb-0.5">Qty Left</p>
              <p class="text-sm font-bold <%= isLow ? 'text-amber-600' : 'text-slate-700' %>">
                <%= crop.quantity > 0 ? crop.quantity + ' kg' : 'Sold out' %>
              </p>
            </div>
            <div class="bg-slate-50 rounded-xl p-2.5">
              <p class="text-[10px] text-slate-400 font-medium mb-0.5">Inquiries</p>
              <p class="text-sm font-bold text-blue-600"><%= crop.buyers %> buyers</p>
            </div>
          </div>

          <!-- Spacer -->
          <div class="flex-1"></div>

          <!-- ── CONTROL STRIP ── -->
          <div class="action-strip flex items-center gap-2 pt-3 border-t border-slate-100">

            <!-- Edit -->
            <a href="/editcrop/<%= crop._id %>"
              class="action-btn-icon flex-1 flex items-center justify-center gap-2 bg-slate-50 hover:bg-emerald-600 text-slate-500 hover:text-white text-xs font-semibold py-2 rounded-xl transition-all duration-200">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
              </svg>
              Edit
            </a>

            <!-- Delete -->
            <form action="/delete/<%= crop._id %>" method="POST"
              onsubmit="return confirmDelete()" class="flex-1">
              <button type="submit"
                class="action-btn-icon w-full flex items-center justify-center gap-2 bg-slate-50 hover:bg-red-500 text-slate-500 hover:text-white text-xs font-semibold py-2 rounded-xl transition-all duration-200">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
                  <polyline points="3 6 5 6 21 6"/>
                  <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/>
                  <path d="M10 11v6M14 11v6M9 6V4h6v2"/>
                </svg>
                Delete
              </button>
            </form>

          </div>
        </div>
      </div>

      <% }); %>
    </div>
  </main>


  <!-- ══════════════════════════════════════════
       FOOTER
  ══════════════════════════════════════════ -->
  <footer class="border-t border-slate-200 bg-white mt-8">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 bg-emerald-600 rounded-md flex items-center justify-center">
          <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17 8C8 10 5.9 16.17 3.82 19c-1.8 2.5-1.52 3-1.52 3H5c1.5-3 6-8 14-8-3 .5-6 2-8 4 2-3 8-5 12-5-5 2-8 6-8 6h3c4-5 10-7 10-7s-6.5 1.5-9 5z"/>
          </svg>
        </div>
        <span class="text-sm font-black text-emerald-700">KRISHIQ</span>
      </div>
      <p class="text-xs text-slate-400">&copy; 2025 KRISHIQ. Empowering Indian farmers.</p>
      <p class="text-xs text-slate-300 font-medium">Built with ❤ for Bharat's Agri-Future</p>
    </div>
  </footer>

</body>
</html>

<script>
  function confirmDelete() {
    return confirm("Are you sure you want to delete this listing?\nThis action cannot be undone.");
  }
</script>