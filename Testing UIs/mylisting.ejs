<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
  <div class="bg-white border border-gray-100 p-5 rounded-2xl shadow-sm">
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Total Listings</p>
    <h3 class="text-2xl font-bold text-gray-800"><%= crops.length %></h3>
  </div>
  <div class="bg-white border border-gray-100 p-5 rounded-2xl shadow-sm">
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Total Inquiries</p>
    <h3 class="text-2xl font-bold text-blue-600"><%= crops.reduce((sum, c)=> sum + c.buyers, 0) %></h3>
  </div>
  <div class="bg-white border border-gray-100 p-5 rounded-2xl shadow-sm">
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Est. Revenue</p>
    <h3 class="text-2xl font-bold text-green-600">₹<%= crops.reduce((sum, c)=> sum + (c.price * c.quantity), 0) %></h3>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  <% crops.forEach(crop => { %>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow group">
      
      <div class="relative h-40 overflow-hidden">
        <img src="<%= crop.image %>" 
             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300 <%= crop.status === 'sold' ? 'grayscale' : '' %>">
        
        <div class="absolute top-3 left-3">
          <% if(crop.status === 'sold' || crop.quantity <= 0) { %>
            <span class="bg-red-500 text-white text-[10px] font-bold px-2 py-1 rounded-full uppercase">Sold Out</span>
          <% } else { %>
            <span class="bg-green-500 text-white text-[10px] font-bold px-2 py-1 rounded-full uppercase">Active</span>
          <% } %>
        </div>
      </div>

      <div class="p-4">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="font-bold text-gray-800 truncate"><%= crop.cropName %></h3>
            <p class="text-xs text-gray-400"><%= crop.category %></p>
          </div>
          <div class="text-right">
            <p class="text-green-600 font-bold text-lg">₹<%= crop.price %></p>
            <p class="text-[10px] text-gray-400">per kg</p>
          </div>
        </div>

        <div class="mt-4 flex items-center justify-between border-t border-gray-50 pt-4">
          <div class="flex flex-col">
            <span class="text-xs text-gray-500 font-medium"><%= crop.quantity %> kg left</span>
            <span class="text-[11px] text-blue-500"><%= crop.buyers %> Interested</span>
          </div>

          <div class="flex gap-2">
            <a href="/editcrop/<%= crop._id %>" 
               class="p-2 bg-gray-50 text-gray-600 rounded-lg hover:bg-green-50 hover:text-green-600 transition-colors"
               title="Edit">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
              </svg>
            </a>
            
            <form action="/delete/<%= crop._id %>" method="POST" onsubmit="return confirmDelete()">
              <button class="p-2 bg-gray-50 text-gray-600 rounded-lg hover:bg-red-50 hover:text-red-600 transition-colors"
                      title="Delete">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</div>