<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KRISHIQ | Professional Agri-Marketplace</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Remix Icons (Professional Icon Set) -->
    <link href="https://jsdelivr.net" rel="stylesheet">
    
    <!-- Google Fonts: Plus Jakarta Sans for a tech-forward look -->
    <link href="https://googleapis.com" rel="stylesheet">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['"Plus Jakarta Sans"', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            50: '#ecfdf5',  // Lightest emerald
                            100: '#d1fae5',
                            500: '#10b981', // Primary action
                            800: '#065f46', // Deep text
                            900: '#064e3b',
                        }
                    },
                    animation: {
                        'marquee': 'marquee 25s linear infinite',
                    },
                    keyframes: {
                        marquee: {
                            '0%': { transform: 'translateX(100%)' },
                            '100%': { transform: 'translateX(-100%)' },
                        }
                    }
                }
            }
        }
    </script>

    <style>
        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
        ::-webkit-scrollbar-thumb { background: #d1fae5; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #10b981; }
        
        .glass-nav {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }
    </style>
</head>
<body class="bg-brand-50 text-gray-800 antialiased selection:bg-brand-100 selection:text-brand-900">

    <!-- MARKET TICKER (New Feature) -->
    <div class="bg-brand-900 text-white text-xs font-medium py-1 overflow-hidden whitespace-nowrap">
        <div class="inline-block animate-marquee">
            <span class="mx-4">📢 Live Mandi Rates:</span>
            <span class="mx-4 text-green-300">Nashik Onion: ₹1,800/q ▲</span>
            <span class="mx-4 text-red-300">Pune Tomato: ₹2,400/q ▼</span>
            <span class="mx-4 text-green-300">Nagpur Orange: ₹4,500/q ▲</span>
            <span class="mx-4 text-gray-300">Indore Soyabean: ₹3,800/q —</span>
            <span class="mx-4 text-green-300">Punjab Wheat: ₹2,100/q ▲</span>
        </div>
    </div>

    <!-- COMPACT GLASS HEADER -->
    <nav class="glass-nav sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4">
            
            <!-- Logo -->
            <div class="flex items-center gap-2 shrink-0 cursor-pointer">
                <div class="w-8 h-8 bg-brand-500 rounded-lg flex items-center justify-center text-white">
                    <i class="ri-plant-fill text-xl"></i>
                </div>
                <span class="text-xl font-extrabold tracking-tight text-brand-900">KRISHIQ</span>
            </div>

            <!-- Search (Compact) -->
            <div class="hidden md:flex flex-1 max-w-md relative group">
                <i class="ri-search-line absolute left-3 top-2.5 text-gray-400 group-focus-within:text-brand-500 transition"></i>
                <input type="text" placeholder="Search crops, farmers, or IDs..." 
                    class="w-full pl-10 pr-4 py-2 rounded-xl bg-gray-100 border-none focus:bg-white focus:ring-2 focus:ring-brand-100 focus:outline-none transition-all text-sm placeholder-gray-500">
            </div>

            <!-- Right Actions -->
            <div class="flex items-center gap-3 sm:gap-5">
                
                <!-- Location (Minimized) -->
                <div class="hidden sm:flex items-center gap-1 text-xs font-medium text-gray-600 bg-gray-100 px-3 py-1.5 rounded-full cursor-pointer hover:bg-brand-100 hover:text-brand-800 transition">
                    <i class="ri-map-pin-line"></i>
                    <span>Pune, MH</span>
                </div>

                <!-- Notifications -->
                <button class="relative p-2 text-gray-500 hover:text-brand-600 transition">
                    <i class="ri-notification-3-line text-xl"></i>
                    <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
                </button>

                <!-- Profile -->
                <div class="w-9 h-9 rounded-full bg-gradient-to-tr from-brand-500 to-brand-300 p-0.5 cursor-pointer">
                    <img src="https://ui-avatars.com" class="rounded-full w-full h-full object-cover border-2 border-white">
                </div>
            </div>
        </div>
    </nav>

    <!-- MOBILE SEARCH (Visible only on small screens) -->
    <div class="md:hidden px-4 py-3 bg-white border-b">
        <div class="relative">
            <i class="ri-search-line absolute left-3 top-2.5 text-gray-400"></i>
            <input type="text" placeholder="Search marketplace..." 
                class="w-full pl-10 pr-4 py-2 rounded-lg bg-gray-50 focus:ring-2 focus:ring-brand-100 outline-none text-sm">
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

        <!-- SECTION HEADER -->
        <div class="flex items-end justify-between mb-6">
            <div>
                <h2 class="text-2xl font-bold text-gray-900">Fresh Feed</h2>
                <p class="text-sm text-gray-500 mt-1">Direct from verified farmers near you.</p>
            </div>
            <button class="flex items-center gap-1 text-sm font-semibold text-brand-600 hover:text-brand-800">
                <i class="ri-filter-3-line"></i> Filter
            </button>
        </div>

        <!-- PRODUCT GRID -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

            <!-- CARD 1 -->
            <div class="group bg-white rounded-2xl border border-gray-100 hover:shadow-xl hover:border-brand-100 transition-all duration-300 flex flex-col relative overflow-hidden">
                
                <!-- Image Area -->
                <div class="relative h-56 w-full overflow-hidden bg-gray-100">
                    <img src="https://unsplash.com" 
                        class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500">
                    
                    <!-- Overlay Badges -->
                    <span class="absolute top-3 left-3 bg-white/90 backdrop-blur text-brand-800 text-xs font-bold px-2.5 py-1 rounded-md shadow-sm flex items-center gap-1">
                        <i class="ri-verified-badge-fill text-blue-500"></i> Verified
                    </span>
                    <span class="absolute top-3 right-3 bg-red-100 text-red-700 text-xs font-bold px-2 py-1 rounded-md">
                        -12%
                    </span>

                    <!-- Hover Action -->
                    <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                        <button class="bg-white text-gray-900 px-4 py-2 rounded-full font-semibold text-sm shadow-lg transform translate-y-4 group-hover:translate-y-0 transition-transform">
                            Quick View
                        </button>
                    </div>
                </div>

                <!-- Content -->
                <div class="p-4 flex-1 flex flex-col">
                    <div class="flex justify-between items-start mb-1">
                        <div>
                            <h3 class="font-bold text-lg text-gray-900 group-hover:text-brand-600 transition">Org. Tomatoes</h3>
                            <p class="text-xs text-gray-500">Hybrid Variant (540)</p>
                        </div>
                        <div class="text-right">
                            <p class="text-xl font-bold text-brand-600">₹28<span class="text-sm font-normal text-gray-400">/kg</span></p>
                        </div>
                    </div>

                    <!-- Seller Line -->
                    <div class="flex items-center gap-2 mt-3 mb-4 pb-3 border-b border-dashed border-gray-100">
                        <img src="https://randomuser.me" class="w-6 h-6 rounded-full">
                        <p class="text-xs text-gray-600 truncate flex-1">Ravi Patel <span class="text-gray-300">|</span> 4.8⭐</p>
                        <span class="text-xs text-gray-400 flex items-center gap-1"><i class="ri-truck-line"></i> 8km</span>
                    </div>

                    <!-- Stock Bar -->
                    <div class="mb-4">
                        <div class="flex justify-between text-[10px] font-medium text-gray-500 mb-1">
                            <span>Available: 300kg</span>
                            <span class="text-orange-500">Selling fast!</span>
                        </div>
                        <div class="w-full bg-gray-100 rounded-full h-1.5">
                            <div class="bg-gradient-to-r from-brand-500 to-brand-300 h-1.5 rounded-full" style="width: 70%"></div>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="mt-auto grid grid-cols-4 gap-2">
                        <button class="col-span-3 bg-gray-900 text-white py-2.5 rounded-xl text-sm font-semibold hover:bg-brand-600 transition flex items-center justify-center gap-2 group-active:scale-95">
                            <i class="ri-shopping-bag-3-line"></i> Buy Now
                        </button>
                        <button class="col-span-1 border border-gray-200 rounded-xl flex items-center justify-center text-gray-500 hover:bg-gray-50 hover:text-brand-600 transition">
                            <i class="ri-message-2-line text-lg"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- CARD 2 -->
            <div class="group bg-white rounded-2xl border border-gray-100 hover:shadow-xl hover:border-brand-100 transition-all duration-300 flex flex-col relative overflow-hidden">
                <div class="relative h-56 w-full bg-gray-100">
                    <img src="https://unsplash.com" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500">
                    <span class="absolute top-3 left-3 bg-orange-100 text-orange-700 text-xs font-bold px-2.5 py-1 rounded-md shadow-sm">
                        Top Rated
                    </span>
                </div>
                <div class="p-4 flex-1 flex flex-col">
                    <div class="flex justify-between items-start mb-1">
                        <div>
                            <h3 class="font-bold text-lg text-gray-900 group-hover:text-brand-600 transition">Red Onions</h3>
                            <p class="text-xs text-gray-500">Nashik Special</p>
                        </div>
                        <div class="text-right">
                            <p class="text-xl font-bold text-brand-600">₹22<span class="text-sm font-normal text-gray-400">/kg</span></p>
                        </div>
                    </div>
                    <div class="flex items-center gap-2 mt-3 mb-4 pb-3 border-b border-dashed border-gray-100">
                        <div class="w-6 h-6 rounded-full bg-purple-100 flex items-center justify-center text-[10px] font-bold text-purple-700">S</div>
                        <p class="text-xs text-gray-600 truncate flex-1">Suresh Agrotech</p>
                        <span class="text-xs text-gray-400">12km</span>
                    </div>
                     <div class="mb-4">
                        <div class="flex justify-between text-[10px] font-medium text-gray-500 mb-1">
                            <span>Available: 1.2 Ton</span>
                        </div>
                        <div class="w-full bg-gray-100 rounded-full h-1.5">
                            <div class="bg-gray-300 h-1.5 rounded-full" style="width: 40%"></div>
                        </div>
                    </div>
                    <div class="mt-auto grid grid-cols-4 gap-2">
                        <button class="col-span-3 bg-gray-900 text-white py-2.5 rounded-xl text-sm font-semibold hover:bg-brand-600 transition flex items-center justify-center gap-2">
                            <i class="ri-shopping-bag-3-line"></i> Buy Now
                        </button>
                        <button class="col-span-1 border border-gray-200 rounded-xl flex items-center justify-center text-gray-500 hover:bg-gray-50 hover:text-brand-600 transition">
                            <i class="ri-message-2-line text-lg"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- CARD 3 (Potatoes) -->
            <div class="group bg-white rounded-2xl border border-gray-100 hover:shadow-xl hover:border-brand-100 transition-all duration-300 flex flex-col relative overflow-hidden">
                <div class="relative h-56 w-full bg-gray-100">
                    <img src="https://unsplash.com" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500">
                </div>
                <div class="p-4 flex-1 flex flex-col">
                    <div class="flex justify-between items-start mb-1">
                        <div>
                            <h3 class="font-bold text-lg text-gray-900 group-hover:text-brand-600 transition">Fresh Potato</h3>
                            <p class="text-xs text-gray-500">Desi Jyoti</p>
                        </div>
                        <div class="text-right">
                            <p class="text-xl font-bold text-brand-600">₹18<span class="text-sm font-normal text-gray-400">/kg</span></p>
                        </div>
                    </div>
                     <div class="flex items-center gap-2 mt-3 mb-4 pb-3 border-b border-dashed border-gray-100">
                        <img src="https://randomuser.me" class="w-6 h-6 rounded-full">
                        <p class="text-xs text-gray-600 truncate flex-1">Meera Farms</p>
                        <span class="text-xs text-gray-400">22km</span>
                    </div>
                    <div class="mt-auto">
                        <div class="flex gap-2 mb-2">
                            <span class="text-[10px] bg-green-50 text-brand-700 px-2 py-1 rounded border border-green-100">Min: 50kg</span>
                            <span class="text-[10px] bg-gray-50 text-gray-600 px-2 py-1 rounded border border-gray-200">Bulk Only</span>
                        </div>
                        <button class="w-full bg-white border border-brand-600 text-brand-600 py-2.5 rounded-xl text-sm font-semibold hover:bg-brand-600 hover:text-white transition">
                            Contact Seller
                        </button>
                    </div>
                </div>
            </div>

            <!-- CARD 4 (Wheat) -->
             <div class="group bg-white rounded-2xl border border-gray-100 hover:shadow-xl hover:border-brand-100 transition-all duration-300 flex flex-col relative overflow-hidden">
                <div class="relative h-56 w-full bg-gray-100">
                    <img src="https://unsplash.com" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500">
                     <div class="absolute inset-0 bg-black/50 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity backdrop-blur-sm">
                         <p class="text-white font-semibold">Harvested yesterday</p>
                     </div>
                </div>
                <div class="p-4 flex-1 flex flex-col">
                    <div class="flex justify-between items-start mb-1">
                        <div>
                            <h3 class="font-bold text-lg text-gray-900 group-hover:text-brand-600 transition">Premium Wheat</h3>
                            <p class="text-xs text-gray-500">Sharbati Grade A</p>
                        </div>
                        <div class="text-right">
                            <p class="text-xl font-bold text-brand-600">₹42<span class="text-sm font-normal text-gray-400">/kg</span></p>
                        </div>
                    </div>
                    <div class="flex items-center gap-2 mt-3 mb-4 pb-3 border-b border-dashed border-gray-100">
                         <i class="ri-shield-check-fill text-blue-500 text-lg"></i>
                        <p class="text-xs text-gray-600 truncate flex-1">Kisan Union #402</p>
                    </div>
                     <div class="mt-auto grid grid-cols-4 gap-2">
                        <button class="col-span-3 bg-gray-900 text-white py-2.5 rounded-xl text-sm font-semibold hover:bg-brand-600 transition flex items-center justify-center gap-2">
                            <i class="ri-shopping-bag-3-line"></i> Buy Now
                        </button>
                        <button class="col-span-1 border border-gray-200 rounded-xl flex items-center justify-center text-gray-500 hover:bg-gray-50 hover:text-brand-600 transition">
                            <i class="ri-message-2-line text-lg"></i>
                        </button>
                    </div>
                </div>
            </div>

        </div>
        
        <!-- LOADING INDICATOR -->
        <div class="flex justify-center mt-12">
            <div class="flex items-center gap-2 text-gray-400 text-sm animate-pulse">
                <div class="w-2 h-2 bg-brand-400 rounded-full"></div>
                <div class="w-2 h-2 bg-brand-400 rounded-full"></div>
                <div class="w-2 h-2 bg-brand-400 rounded-full"></div>
                <span>Loading more crops...</span>
            </div>
        </div>

    </main>

</body>
</html>
