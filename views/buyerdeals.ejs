<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>My Deals - KRISHIQ</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-50 text-gray-900">


    <header class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-gray-200">

        <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
            <div class="flex items-center gap-3">

                <span class="text-lg font-semibold text-green-700">
                    KRISHIQ
                </span>
            </div>
            <div class="flex items-center gap-4 text-sm">

                <a href="/marketplace" class="text-gray-600 hover:text-green-700">
                   Marketplace
                </a>

                <a href="/mydeals" class="text-gray-600 hover:text-green-700">
                   Deals
                </a>

                <a href="/mylistings" class="text-gray-600 hover:text-green-700">
                    My Listings
                </a>

                <div class="relative">
                    <img src="https://i.pravatar.cc/40"
                        class="w-10 h-10 rounded-full cursor-pointer border-2 border-gray-300">
                </div>

            </div>

        </div>

    </header>



    <div class="max-w-6xl mx-auto px-6 py-10">

        <h1 class="text-2xl font-bold mb-6">My Deals 🤝</h1>

        <!-- EMPTY STATE -->
        <% if (!deals || deals.length===0) { %>
            <p class="text-gray-500">No deals yet.</p>
            <% } %>

                <!-- DEAL GRID -->
                <div class="grid md:grid-cols-3 gap-6">

                    <% deals.forEach(deal=> { %>

                        <div class="bg-white rounded-xl shadow-md p-5 hover:shadow-xl transition">

                            <!-- CROP NAME -->
                            <h2 class="text-lg font-semibold mb-2">
                                <% if (deal.cropId) { %>
                                    <%= deal.cropId.cropName %>
                                        <% } else { %>
                                            Unknown Crop
                                            <% } %>
                            </h2>

                            <!-- ORIGINAL PRICE -->
                            <p class="text-gray-500 text-sm mb-1">
                                Original Price: ₹
                                <% if (deal.cropId) { %>
                                    <%= deal.cropId.price %>
                                        <% } %>
                            </p>

                            <!-- OFFER -->
                            <p class="text-gray-800 font-medium">
                                Your Offer: ₹<%= deal.offeredPrice %>
                            </p>

                            <!-- QUANTITY -->
                            <p class="text-gray-500 text-sm mt-1">
                                Quantity: <%= deal.quantity %> kg
                            </p>


                            <div class="flex justify-between items-center">
                                <!-- STATUS -->
                                <p class="mt-3 text-sm">
                                    Status:
                                    <% if (deal.status==="pending" ) { %>
                                        <span class="text-yellow-500 font-medium">🟡 Pending</span>
                                        <% } else if (deal.status==="accepted" ) { %>
                                            <span class="text-green-600 font-medium">🟢 Accepted</span>
                                            <% } else { %>
                                                <span class="text-red-500 font-medium">🔴 Rejected</span>
                                                <% } %>
                                </p>



                                <form action="/deletebuyerdeal/<%= deal._id %>" method="POST"
                                    onsubmit="return confirmDelete('Do you really want to delete this listing!')">

                                    <button class="px-3 mt-3 py-1 bg-red-100 text-red-600 rounded">
                                        Delete
                                    </button>

                                </form>
                            </div>
                        </div>

                        <% }) %>

                </div>

    </div>

</body>

</html>