<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Crop | KRISHIQ</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        /* Custom scrollbar for textareas */
        textarea::-webkit-scrollbar { width: 8px; }
        textarea::-webkit-scrollbar-track { background: transparent; }
        textarea::-webkit-scrollbar-thumb { background-color: #cbd5e1; border-radius: 20px; border: 3px solid transparent; background-clip: content-box; }
    </style>
</head>
<body class="bg-slate-50 bg-[radial-gradient(ellipse_at_top_left,_var(--tw-gradient-stops))] from-green-50/60 via-slate-50 to-slate-100 text-slate-800 min-h-screen antialiased selection:bg-green-100 selection:text-green-900">

    <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-200/80">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-2 cursor-pointer">
                    <div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center shadow-sm shadow-green-600/20">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path>
                        </svg>
                    </div>
                    <span class="font-bold text-xl tracking-tight text-slate-900">KRISHIQ</span>
                </div>
                <div class="flex items-center gap-4">
                    <button class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-green-500/20">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                    </button>
                    <div class="w-9 h-9 rounded-full bg-slate-200 border-2 border-white shadow-sm overflow-hidden cursor-pointer">
                        <img src="https://api.dicebear.com/7.x/notionists/svg?seed=Felix" alt="User" class="w-full h-full object-cover">
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
        
        <div class="mb-8">
            <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight">Add New Crop</h1>
            <p class="text-slate-500 mt-2 text-sm sm:text-base max-w-2xl">Enter the details of your harvest to list it on the marketplace. Accurate descriptions help buyers make quicker decisions.</p>
        </div>

        <form action="/crops/add" method="POST" enctype="multipart/form-data" class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
            
            <div class="lg:col-span-2 space-y-6">
                <div class="bg-white rounded-2xl shadow-[0_2px_12px_rgb(0,0,0,0.03)] border border-slate-200/60 p-6 sm:p-8">
                    
                    <h2 class="text-lg font-semibold text-slate-900 mb-6 flex items-center gap-2">
                        <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        General Information
                    </h2>

                    <div class="space-y-5">
                        <div>
                            <label for="name" class="block text-sm font-medium text-slate-700 mb-1.5">Crop Name</label>
                            <input type="text" id="name" name="name" placeholder="e.g. Organic Basmati Rice" required
                                class="w-full rounded-xl border border-slate-200 bg-slate-50/50 px-4 py-3 text-sm text-slate-900 placeholder-slate-400 focus:border-green-500 focus:bg-white focus:ring-4 focus:ring-green-500/10 transition-all duration-200 outline-none">
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                            <div>
                                <label for="category" class="block text-sm font-medium text-slate-700 mb-1.5">Category</label>
                                <div class="relative">
                                    <select id="category" name="category" required
                                        class="w-full appearance-none rounded-xl border border-slate-200 bg-slate-50/50 px-4 py-3 pr-10 text-sm text-slate-900 focus:border-green-500 focus:bg-white focus:ring-4 focus:ring-green-500/10 transition-all duration-200 outline-none">
                                        <option value="" disabled selected>Select category</option>
                                        <option value="grains">Grains & Cereals</option>
                                        <option value="vegetables">Vegetables</option>
                                        <option value="fruits">Fruits</option>
                                        <option value="spices">Spices & Herbs</option>
                                        <option value="pulses">Pulses & Legumes</option>
                                    </select>
                                    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-slate-400">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <label for="grade" class="block text-sm font-medium text-slate-700 mb-1.5">Quality Grade</label>
                                <div class="relative">
                                    <select id="grade" name="grade" 
                                        class="w-full appearance-none rounded-xl border border-slate-200 bg-slate-50/50 px-4 py-3 pr-10 text-sm text-slate-900 focus:border-green-500 focus:bg-white focus:ring-4 focus:ring-green-500/10 transition-all duration-200 outline-none">
                                        <option value="" disabled selected>Select grade</option>
                                        <option value="A">Grade A (Premium)</option>
                                        <option value="B">Grade B (Standard)</option>
                                        <option value="C">Grade C (Processing)</option>
                                    </select>
                                    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-slate-400">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="h-px w-full bg-slate-100 my-2"></div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                            <div>
                                <label for="price" class="block text-sm font-medium text-slate-700 mb-1.5">Price (per unit)</label>
                                <div class="relative">
                                    <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-4 text-slate-400">
                                        <span class="text-sm font-medium">₹</span>
                                    </div>
                                    <input type="number" id="price" name="price" placeholder="0.00" min="0" step="0.01" required
                                        class="w-full rounded-xl border border-slate-200 bg-slate-50/50 pl-8 pr-4 py-3 text-sm text-slate-900 placeholder-slate-400 focus:border-green-500 focus:bg-white focus:ring-4 focus:ring-green-500/10 transition-all duration-200 outline-none">
                                </div>
                            </div>

                            <div class="grid grid-cols-2 gap-3">
                                <div>
                                    <label for="quantity" class="block text-sm font-medium text-slate-700 mb-1.5">Available Qty</label>
                                    <input type="number" id="quantity" name="quantity" placeholder="100" min="1" required
                                        class="w-full rounded-xl border border-slate-200 bg-slate-50/50 px-4 py-3 text-sm text-slate-900 placeholder-slate-400 focus:border-green-500 focus:bg-white focus:ring-4 focus:ring-green-500/10 transition-all duration-200 outline-none">
                                </div>
                                <div>
                                    <label for="unit" class="block text-sm font-medium text-slate-700 mb-1.5">Unit</label>
                                    <div class="relative">
                                        <select id="unit" name="unit" required
                                            class="w-full appearance-none rounded-xl border border-slate-200 bg-slate-50/50 px-4 py-3 pr-10 text-sm text-slate-900 focus:border-green-500 focus:bg-white focus:ring-4 focus:ring-green-500/10 transition-all duration-200 outline-none">
                                            <option value="kg">Quintal</option>
                                            <option value="ton">Ton</option>
                                            <option value="kg">Kg</option>
                                        </select>
                                        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-slate-400">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div>
                            <label for="description" class="block text-sm font-medium text-slate-700 mb-1.5">Description</label>
                            <textarea id="description" name="description" rows="4" placeholder="Mention farming methods, harvest date, or any specific details..."
                                class="w-full rounded-xl border border-slate-200 bg-slate-50/50 px-4 py-3 text-sm text-slate-900 placeholder-slate-400 focus:border-green-500 focus:bg-white focus:ring-4 focus:ring-green-500/10 transition-all duration-200 outline-none resize-y"></textarea>
                        </div>
                    </div>
                </div>

                <div class="flex items-center justify-end gap-3 pt-2">
                    <button type="button" class="px-6 py-2.5 text-sm font-medium text-slate-600 bg-white border border-slate-200 rounded-xl hover:bg-slate-50 hover:text-slate-900 focus:outline-none focus:ring-4 focus:ring-slate-100 transition-all duration-200">
                        Cancel
                    </button>
                    <button type="submit" class="px-6 py-2.5 text-sm font-medium text-white bg-green-600 rounded-xl shadow-sm shadow-green-600/20 hover:bg-green-700 hover:shadow-md hover:shadow-green-600/30 focus:outline-none focus:ring-4 focus:ring-green-500/20 active:scale-[0.98] transition-all duration-200 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        List Crop
                    </button>
                </div>
            </div>

            <div class="lg:col-span-1 space-y-6">
                
                <div class="bg-white rounded-2xl shadow-[0_2px_12px_rgb(0,0,0,0.03)] border border-slate-200/60 p-6">
                    <h2 class="text-base font-semibold text-slate-900 mb-1">Crop Media</h2>
                    <p class="text-xs text-slate-500 mb-4">Upload high-quality images to attract more buyers.</p>

                    <div class="relative group cursor-pointer">
                        <input type="file" id="images" name="images" multiple accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                        <div class="border-2 border-dashed border-slate-200 rounded-xl bg-slate-50/50 p-8 text-center group-hover:bg-green-50/50 group-hover:border-green-400/60 transition-all duration-200 flex flex-col items-center justify-center gap-3">
                            <div class="w-12 h-12 bg-white rounded-full shadow-sm border border-slate-100 flex items-center justify-center text-green-600 group-hover:scale-110 transition-transform duration-200">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            </div>
                            <div>
                                <span class="text-sm font-medium text-green-600">Click to upload</span>
                                <span class="text-sm text-slate-500"> or drag and drop</span>
                            </div>
                            <p class="text-xs text-slate-400">PNG, JPG, WEBP up to 5MB</p>
                        </div>
                    </div>
                </div>

                <div class="bg-gradient-to-br from-green-50 to-emerald-50/30 rounded-2xl p-6 border border-green-100/60 shadow-sm shadow-green-100/20 relative overflow-hidden">
                    <div class="absolute -right-6 -top-6 w-24 h-24 bg-green-200/40 rounded-full blur-2xl pointer-events-none"></div>
                    
                    <h3 class="text-sm font-bold text-green-900 mb-3 flex items-center gap-2">
                        <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg>
                        Tips for a Great Listing
                    </h3>
                    <ul class="space-y-2.5 text-xs text-green-800/80">
                        <li class="flex items-start gap-2">
                            <span class="w-1.5 h-1.5 rounded-full bg-green-400 mt-1.5 shrink-0"></span>
                            Take photos in natural daylight for accurate colors.
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="w-1.5 h-1.5 rounded-full bg-green-400 mt-1.5 shrink-0"></span>
                            Include a close-up shot to show the texture and quality.
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="w-1.5 h-1.5 rounded-full bg-green-400 mt-1.5 shrink-0"></span>
                            Be transparent about the grade and any pesticide usage.
                        </li>
                    </ul>
                </div>
                
            </div>
        </form>
    </main>

</body>
</html>