<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KRISHIQ Marketplace</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-[#f9fafb] text-gray-800 font-sans">


    <nav class="bg-white px-[5%] py-4 flex justify-between items-center shadow-sm sticky top-0 z-50">
        <div class="text-2xl font-bold text-green-600 tracking-tight">KRISHIQ</div>
        <div class="space-x-6 text-sm  flex items-center">


            <span class="text-gray-500 cursor-pointer hover:text-green-500 transition-colors">Cart</span>
            <span class="text-gray-500 cursor-pointer hover:text-green-500 transition-colors">Orders</span>
            <div class="relative">
                <img src="https://i.pravatar.cc/40"
                    class="w-10 h-10 rounded-full cursor-pointer border-2 border-gray-300">
            </div>
        </div>
    </nav>


    <div class="max-w-7xl mx-auto px-6 py-12 text-center">
        <h1 class="text-3xl md:text-4xl font-bold mb-3">Buy Crops Directly From Farmers</h1>
        <p class="text-gray-500 mb-8">Fair Prices • Fresh Harvest • No Middlemen</p>

        <div class="flex justify-center">
            <input type="text" placeholder="Search crops like wheat, tomatoes, onions..."
                class="w-full max-w-lg px-6 py-4 rounded-full border border-gray-200 shadow-md focus:outline-none focus:ring-1 focus:ring-green-500 focus:border-transparent transition-all">
        </div>
    </div>


    <div class="max-w-7xl mx-auto px-6 pb-20">
        <div class="flex justify-between items-center mb-8">
            <h2 class="text-2xl font-bold">Nearby Crops</h2>
        </div>
        <div class="bg-zinc-300 h-[1px] mb-6"></div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">



            <% crops.forEach(crop=> { %>

                <div
                    class="bg-white rounded-xl overflow-hidden shadow-md hover:shadow-xl hover:-translate-y-2 transition-all duration-300">

                    <img src="https://images.unsplash.com/photo-1574323347407-f5e1ad6d020b" class="w-full h-48 object-cover" alt="<%= crop.name %>">

                    <div class="p-5">

                        <div class="text-lg font-bold mb-1">
                            <%= crop.cropName %>
                        </div>

                        <div class="text-xs text-gray-500 mb-3">
                            👨‍🌾 Rajesh singh
                            <!-- <%= crop.farmer %> -->
                        </div>

                        <div class="flex items-center justify-between text-sm text-gray-600 mb-4">

                            <div class="flex items-center gap-2">
                                <span class="font-medium text-gray-800">
                                    <!-- <%= crop.rating %> -->
                                     4.8
                                </span>
                                <span class="text-gray-400">rating</span>
                            </div>

                            <div class="flex items-center gap-1 text-gray-500">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24"
                                    stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M12 11c0-1.657-1.343-3-3-3S6 9.343 6 11c0 3 3 7 3 7s3-4 3-7z" />
                                </svg>
                                <span>
                                    <!-- <%= crop.distance %> km -->
                                     10 km
                                </span>
                            </div>

                        </div>

                        <div class="text-[#56d408] text-lg font-bold mb-4">
                            ₹<%= crop.price %> / Quintal
                        </div>

                        <div class="text-[#393939] text-md font-bold mb-4">
                            ₹<%= crop.quantity %> Kg
                        </div>

                        <button
                            class="w-full bg-[#56d408] text-white font-bold py-3 rounded-lg hover:opacity-90 transition-opacity">
                            View Details
                        </button>

                    </div>
                </div>

                <% }) %>

