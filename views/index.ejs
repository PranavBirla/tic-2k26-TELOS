      <div class="flex items-center gap-3 mb-1">
        <img src="https://randomuser.me/api/portraits/men/45.jpg" alt="Suresh Yadav" class="w-10 h-10 rounded-full object-cover shadow-sm">
        <h4 class="font-semibold">Suresh Yadav</h4>
      </div>
      
      <p class="text-xs text-gray-500">Farmer, Indore</p>
    </div>
  </div>
