    <div class="bg-white border p-6 rounded-xl shadow hover:bg-gray-100 hover:shadow-lg transition-all duration-300 transform hover:scale-105">
      <p class="text-gray-600 mb-4">“I earned 20% more selling through Krishiq.”</p>
      
      
      <div class="flex items-center gap-3 mb-1">
        <img src="https://randomuser.me/api/portraits/men/32.jpg" alt="Ramesh Patel" class="w-10 h-10 rounded-full object-cover shadow-sm">
        <h4 class="font-semibold">Ramesh Patel</h4>
