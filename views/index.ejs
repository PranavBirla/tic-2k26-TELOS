<section id="contact" class="py-16 lg:py-18 text-black text-center">
  <h2 class="text-3xl font-bold mb-4 text-white">Start Trading Smarter Today</h2>
  <p class="mb-6 text-gray-200">Join Krishiq and grow your farming business.</p>
  <div class="flex justify-center gap-4">
    <a href="/signup" class="bg-yellow-500 hover:bg-yellow-400 px-6 py-3 rounded-lg font-semibold shadow transition transform hover:-translate-y-1 text-gray-900">
    Continue
    </a>
