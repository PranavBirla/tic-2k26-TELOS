     class="w-64 h-64 rounded-full object-cover shadow-lg transition-all duration-300 hover:shadow-[0_0_20px_rgba(255,255,255,0.8)] hover:scale-105">
</div>
  </div>
</section> 


<section id="why" class="py-8 lg:py-10 scroll-mt-24">
    <h2 class="text-4xl lg:text-4xl font-bold mb-12 text-center lg:text-center text-white">
    Krishiq in Action
  </h2>
  <div class="max-w-6xl mx-auto px-4 flex flex-col lg:flex-row items-center gap-8">

    
    <div class="w-full lg:w-1/2 flex justify-center lg:justify-center hidden lg:flex">
    <img src="https://images.pexels.com/photos/6465/man-field-smartphone-yellow.jpg" 
