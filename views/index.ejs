</section>

<footer class="bg-gray-900 text-gray-400 py-10">
  <div class="max-w-6xl mx-auto px-4 grid md:grid-cols-3 gap-6">
    <div>
      <h3 class="text-white font-semibold mb-2">Krishiq</h3>
      <p class="text-sm">Direct farm trade platform.</p>
    </div>
    <div>
      <h4 class="text-white font-semibold mb-2">Links</h4>
      <ul class="text-sm space-y-1">
        <li>Home</li>
        <li>Listings</li>
        <li>Contact</li>
      </ul>
    </div>
    <div>
      <h4 class="text-white font-semibold mb-2">Contact</h4>
      <p class="text-sm">support@krishiq.com</p>
    </div>
  </div>
</footer>

<script>
const nav = document.getElementById("navbar");
const logo = nav.querySelector("div");
const links = nav.querySelectorAll("a");

window.addEventListener("scroll", () => {
  if (window.scrollY > 70) {
    nav.classList.add("bg-white/90","backdrop-blur","shadow");
    logo.classList.remove("text-white");
    logo.classList.add("text-green-700");
    links.forEach(a => {
      a.classList.remove("text-white");
      a.classList.add("text-gray-800");
    });
  } else {
    nav.classList.remove("bg-white/90","backdrop-blur","shadow");
    logo.classList.remove("text-green-700");
    logo.classList.add("text-white");
    links.forEach(a => {
      a.classList.remove("text-gray-800");
      a.classList.add("text-white");
    });
  }
});
</script>

</body>
</html>