<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Krishiq | Buyer Dashboard</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&family=DM+Sans:wght@400;500&display=swap"
        rel="stylesheet">

    <style>
        body {
            font-family: 'DM Sans', sans-serif;
            background: #F9FAFB;
        }

        h1,
        h2,
        h3 {
            font-family: 'Sora', sans-serif;
        }
    </style>
</head>

<body class="bg-gray-200">

    <!-- NAVBAR -->
    <nav class="bg-white shadow-2xl rounded-full m-10 w-9/12 mx-auto border-b sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">

            <div class="text-xl font-bold text-green-600">
                Krishiq
            </div>

            <div class="flex items-center space-x-6">

                <a href="/marketplace" class="text-gray-600 hover:text-green-600">
                    Marketplace
                </a>

                <a href="/buyerdeals" class="text-gray-600 hover:text-green-600">
                    My Deals
                </a>

                <img src="https://i.pravatar.cc/40"
                    class="w-10 h-10 rounded-full border-2 border-gray-300">

            </div>
        </div>
    </nav>

    <!-- MAIN -->
    <div class="max-w-7xl mx-auto px-6 mt-8 flex flex-col lg:flex-row gap-6">

        <!-- LEFT SIDE -->
        <div class="flex-1 space-y-6">

            <!-- STATS -->
            <div class="grid grid-cols-2 gap-4 lg:flex">

                <div class="bg-white p-6 rounded-xl shadow-lg lg:w-1/4">
                    <p class="text-gray-500 text-sm">Total Purchases</p>
                    <p class="text-3xl font-bold text-gray-700">
                        <%= deals.length %>
                    </p>
                </div>

                <div class="bg-white p-6 rounded-xl shadow-lg lg:w-1/4">
                    <p class="text-gray-500 text-sm">Active Deals</p>
                    <p class="text-3xl font-bold text-gray-700">
                        <%= deals.filter(d => d.status === "pending").length %>
                    </p>
                </div>

                <div class="bg-white p-6 rounded-xl shadow-lg lg:w-1/4">
                    <p class="text-gray-500 text-sm">Completed Deals</p>
                    <p class="text-3xl font-bold text-gray-700">
                        <%= deals.filter(d => d.status === "accepted").length %>
                    </p>
                </div>

                <div class="bg-white p-6 rounded-xl shadow-lg lg:w-1/4">
                    <p class="text-gray-500 text-sm">Total Spend</p>
                    <p class="text-3xl font-bold text-gray-600">
                        ₹<%= deals.reduce((sum, d) => sum + (d.offeredPrice * d.quantity), 0) %>
                    </p>
                </div>

            </div>

            <!-- QUICK ACTIONS -->
            <div class="bg-white p-6 rounded-xl shadow-lg">

                <h2 class="text-lg font-semibold mb-4">
                    Quick Actions
                </h2>

                <div class="flex flex-wrap gap-4 lg:justify-center">

                    <a class="bg-green-500 text-white px-5 py-2 rounded-lg hover:bg-green-600"
                        href="/marketplace">
                        Browse Crops
                    </a>

                    <a class="bg-green-500 text-white px-5 py-2 rounded-lg hover:bg-green-600"
                        href="/buyerdeals">
                        View Deals
                    </a>

                </div>
            </div>

            <!-- RECENT DEALS -->
            <div class="bg-white p-6 rounded-xl shadow-lg">

                <h2 class="text-lg font-semibold mb-4 font-bold">
                    Recent Deals
                </h2>

                <div class="grid md:grid-cols-3 gap-4">

                    <% deals.slice(0,3).forEach(deal => { %>

                    <div class="border bg-gray-100 p-4 rounded-lg">

                        <h3 class="font-semibold">
                            <%= deal.cropId.cropName %>
                        </h3>

                        <p class="text-gray-500">
                            ₹<%= deal.offeredPrice %> / kg
                        </p>

                        <p class="text-sm text-gray-500">
                            Qty: <%= deal.quantity %> kg
                        </p>

                        <p class="text-sm text-gray-400">
                            Status: <%= deal.status %>
                        </p>

                    </div>

                    <% }) %>

                </div>

            </div>

        </div>

        <!-- RIGHT SIDE -->
        <div class="w-full lg:w-80 space-y-6">

            <!-- PROFILE CARD -->
            <div class="bg-white p-6 rounded-xl shadow text-center shadow-lg">

                <img src="https://i.pravatar.cc/100"
                    class="w-20 h-20 rounded-full mx-auto" />

                <h2 class="mt-3 font-semibold">
                    <%= user.username %>
                </h2>

                <p class="text-gray-500 text-sm">
                    <%= user.location %>
                </p>

                <p class="text-gray-500 text-sm">
                    <%= user.contact %>
                </p>

                <button class="mt-4 bg-green-600 text-white px-4 py-2 rounded-lg">
                    Edit Profile
                </button>

            </div>

            <!-- BUYER STATS -->
            <div class="bg-amber-300 p-6 rounded-xl shadow-lg">

                <h3 class="font-semibold mb-3">
                    Buyer Stats
                </h3>

                <p class="text-gray-600">
                    Member Since: 2024
                </p>

                <p class="text-gray-600">
                    Total Orders: <%= deals.length %>
                </p>

                <p class="text-gray-600">
                    Trusted Buyer
                </p>

                <div class="flex justify-end mt-4">
                    <a class="font-bold bg-white border border-red-600 text-red-600 px-4 py-2 rounded-lg"
                        href="/logout">
                        Log out
                    </a>
                </div>

            </div>

        </div>

    </div>

</body>
</html>