<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KRISHIQ - Add Crop</title>


  <script src="https://cdn.tailwindcss.com"></script>


  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    body {
      font-family: 'Inter', sans-serif;
    }
  </style>
</head>

<body class="bg-gray-50 text-gray-900">

  <nav
        class="items-center flex  m-10 top-5 my-5 rounded-full bg-white w-9/12 mx-auto z-50 navbar-blur  border-b border-[#E5E7EB] shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">


                <a href="/" class="flex items-center gap-2.5 group">
                    <div class="w-8 h-8 logo-dot rounded-lg flex items-center justify-center shadow-sm">
                        <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                            <path
                                d="M17 8C8 10 5.9 16.17 3.82 21C7.3 18 13.62 16 17 8zM21 3c-3.81 4-9.12 5-13 6-1.84.48-3.42 1.32-4.79 2.37A11.53 11.53 0 0 0 2.5 14c1.62-1.08 3.48-1.81 5.5-2a18.94 18.94 0 0 1 7 1.06C17.41 14.5 19.5 16.36 20 19c1.1-2.5 1.5-5 .78-7.5.41-.36.82-.74 1.22-1.13V3z" />
                        </svg>
                    </div>
                    <span class="font-heading font-semibold text-lg text-[#111827] tracking-tight">
                        Krishi<span class="text-[#16A34A]">q</span>
                    </span>
                </a>


                <div class="hidden md:flex items-center gap-1">
                    <a href="/listings"
                        class="flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium text-[#6B7280] hover:text-[#16A34A] hover:bg-[#DCFCE7] transition-colors duration-150">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                        </svg>
                        My Listings
                    </a>
                    <a href="/deals"
                        class="flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium text-[#16A34A] bg-[#DCFCE7] transition-colors duration-150">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                        </svg>
                        Deals
                    </a>
                    <a href="/marketplace"
                        class="flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium text-[#6B7280] hover:text-[#16A34A] hover:bg-[#DCFCE7] transition-colors duration-150">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                        </svg>
                        Marketplace
                    </a>
                </div>


                <div class="flex items-center gap-3">
                    <button
                        class="relative p-2 rounded-lg text-[#6B7280] hover:text-[#16A34A] hover:bg-[#DCFCE7] transition-colors duration-150">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                        </svg>
                        <span
                            class="absolute top-1.5 right-1.5 w-2 h-2 bg-[#EF4444] rounded-full border-2 border-white"></span>
                    </button>
                    <a href="/profile" class="flex items-center gap-2 group">
                        <div class="w-9 h-9 rounded-full overflow-hidden avatar-ring">
                            <img src="https://ui-avatars.com/api/?name=Ramesh+Kumar&background=16A34A&color=fff&size=80"
                                alt="Ramesh Kumar" class="w-full h-full object-cover" />
                        </div>
                        <span
                            class="hidden sm:block text-sm font-medium text-[#111827] group-hover:text-[#16A34A] transition-colors duration-150">Ramesh</span>
                    </a>
                 
                    <button
                        class="md:hidden p-2 rounded-lg text-[#6B7280] hover:bg-[#F9FAFB] transition-colors duration-150">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                    </button>
                </div>

            </div>
        </div>
    </nav>


  <div class="max-w-6xl mx-auto px-6 py-10">
    <h2 class="text-2xl font-semibold">Add New Crop</h2>
    <p class="text-gray-500 text-sm mt-1 mb-6">Create a professional marketplace listing</p>

    <form method="POST" action="/addcrop" class="grid md:grid-cols-3 gap-6">

      <div class="md:col-span-2 bg-white p-6 rounded-xl border border-gray-200 shadow-sm">
        <h3 class="text-sm font-semibold mb-4">Crop Information</h3>

        <div class="mb-4">
          <label class="text-xs text-gray-500">Crop Name</label>
          <input name="cropName" type="text" required
            class="w-full mt-1 px-3 py-2 border border-gray-200 rounded-lg focus:ring-1 focus:ring-green-500 outline-none shadow"
            placeholder="Premium Basmati Rice">
        </div>

        <div class="grid grid-cols-2 gap-4 mb-4">
          <div>
            <label class="text-xs text-gray-500">Category</label>
            <select name="category" required
              class="w-full mt-1 px-3 py-2 border border-gray-200 rounded-lg focus:ring-1 focus:ring-green-500 shadow">
              <option>Grains</option>
              <option>Vegetables</option>
              <option>Fruits</option>
            </select>
          </div>

          <div>
            <label class="text-xs text-gray-500">Harvest Date</label>
            <input name="harvestDate" type="date" required
              class="w-full mt-1 px-3 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-green-500 shadow">
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4 mb-4">
          <div>
            <label class="text-xs text-gray-500">Price (₹)</label>
            <input name="price" type="number" required
              class="w-full mt-1 px-3 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-green-500 shadow"
              placeholder="0">
          </div>

          <div>
            <label class="text-xs text-gray-500">Quantity (kg)</label>
            <input name="quantity" type="number" required
              class="w-full mt-1 px-3 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-green-500 shadow"
              placeholder="500">
          </div>
        </div>

        <div>
          <label class="text-xs text-gray-500 ">Description</label>
          <textarea name="description" rows="4"
            class="w-full mt-1 px-3 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-green-500 shadow"
            placeholder="Add crop quality, storage, etc..."></textarea>
        </div>
      </div>


      <div class="space-y-6">

        <div class="bg-white p-6 rounded-xl border border-gray-200 shadow-sm">

          <h3 class="text-lg font-semibold text-gray-800">Crop Media</h3>
          <p class="text-sm text-gray-500 mb-4">
            Upload high-quality images to attract more buyers.
          </p>

          <label class="flex flex-col items-center justify-center border-2 border-dashed border-gray-300 rounded-xl p-10 text-center cursor-pointer 
           hover:border-green-500 hover:bg-green-50 transition">

            <input type="file" name="image" id="fileInput" class="hidden" accept="image/*"
              onchange="previewImage(event)">

            <div class="w-16 h-16 flex items-center justify-center rounded-full bg-gray-100 shadow-sm mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-green-500" fill="none" viewBox="0 0 24 24"
                stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M12 16V4m0 0l-4 4m4-4l4 4M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2" />
              </svg>
            </div>
          
            <p id="uploadText" class="text-sm">
              <span class="text-green-500 font-medium">Click to upload</span>
              <span class="text-gray-500"> or drag and drop</span>
            </p>

            <p class="text-xs text-gray-400 mt-1">
              PNG, JPG, WEBP up to 5MB
            </p>

            
            <img id="preview" class="hidden mt-4 rounded-lg max-h-40 shadow">

          </label>

        </div>

        <div class="bg-green-500 text-white p-5 rounded-xl text-sm shadow">
          Listings with images and proper pricing get 3x more engagement.
        </div>

      </div>


      <div class="md:col-span-3 flex justify-end gap-3 mt-2">
        <a type="button" href="/mylistings"
          class="px-5 py-2 rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-100">Cancel</a>
        <button type="submit" class="px-5 py-2 rounded-lg bg-green-500 text-white hover:bg-green-600 shadow">
          Publish Crop
        </button>
      </div>

    </form>


  </div>

</body>
<script>

  function previewImage(event) {
    const file = event.target.files[0];
    if (!file) return;

    const preview = document.getElementById("preview");
    const text = document.getElementById("uploadText");

    preview.src = URL.createObjectURL(file);
    preview.classList.remove("hidden");

    text.classList.add("hidden");
  }

</script>

</html>