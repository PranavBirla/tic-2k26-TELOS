<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Krishiq | Farmer Dashboard</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&family=DM+Sans:wght@400;500&display=swap"
        rel="stylesheet">

    <style>
        body {
            font-family: 'DM Sans', sans-serif;
            background: #F9FAFB;
        }

        h1,
        h2,
        h3 {
            font-family: 'Sora', sans-serif;
        }
    </style>

</head>

<body>

    <header
        class="bg-white shadow-2xl rounded-full m-10 w-11/12 md:w-9/12 mx-auto border-b border-gray-200 px-3 md:px-10 py-4 flex justify-between items-center">

        <h1 class="text-green-700 font-semibold text-lg">KRISHIQ</h1>

        <div class="flex items-center space-x-6">

            <a href="/mylistings" class="text-gray-600 hover:text-green-600">
                My Listings
            </a>

            <a href="/farmerdeals" class="text-gray-600 hover:text-green-600">
                Deals
            </a>

            <div class="relative">
                <img src="https://i.pravatar.cc/40"
                    class="w-10 h-10 rounded-full cursor-pointer border-2 border-gray-300">
            </div>
            </nav>

    </header>




    <div class="max-w-7xl mx-auto px-6 mt-8 flex flex-col lg:flex-row gap-6">




        <div class="flex-1 space-y-6">




            <div class="grid grid-cols-2 gap-4 lg:flex ">

                <div class="bg-white p-6 rounded-xl shadow-lg lg:w-1/4">
                    <p class="text-gray-500 text-sm">My Listings</p>
                    <p class="text-3xl font-bold text-gray-700">8</p>
                </div>

                <div class="bg-white p-6 rounded-xl shadow-lg lg:w-1/4">
                    <p class="text-gray-500 text-sm">Active Deals</p>
                    <p class="text-3xl font-bold text-gray-700">3</p>
                </div>

                <div class="bg-white p-6 rounded-xl shadow-lg lg:w-1/4">
                    <p class="text-gray-500 text-sm">Completed Deals</p>
                    <p class="text-3xl font-bold text-gray-700">12</p>
                </div>

                <div class="bg-white p-6 rounded-xl shadow-lg lg:w-1/4">
                    <p class="text-gray-500 text-sm">Revenue This Month</p>
                    <p class="text-3xl font-bold text-gray-600">₹18,500</p>
                </div>

            </div>


            <div class="bg-white p-6 rounded-xl shadow-lg lg:w-full">

                <h2 class="text-lg font-semibold mb-4">
                    Quick Actions
                </h2>

                <div class="flex flex-wrap gap-4 lg:justify-center  ">

                    <a class="bg-green-500 text-white
                    p px-5 py-2 rounded-lg hover:bg-green-600" href="/addcrop">
                        Add Listing
                    </a>

                    <a class="bg-green-500 text-white
                    px-5 py-2 rounded-lg hover:bg-green-600" href="/mylistings">
                        View Listing
                    </a>

                    <a class="bg-green-500 text-white
                    p px-5 py-2 rounded-lg hover:bg-green-600" href="/farmerdeals">
                        Check Deals
                    </a>


                </div>

            </div>



            <div class="bg-gradient-to-r from-blue-800 via-indigo-900 to-pink-500 p-6 rounded-2xl shadow-lg text-white">

                <!-- Heading -->
                <div class="text-center mb-6">
                    <h1 class="text-4xl font-bold">AI Price Suggestion</h1>
                </div>
            
                <!-- Input + Button Row -->
                <div class="flex gap-3 items-center justify-center mb-6">
            
                    <input 
                        name="cropName" 
                        type="text" 
                        required
                        class="w-2/3 px-4 py-2 rounded-lg bg-white/10 backdrop-blur border border-white/20 focus:ring-2 focus:ring-yellow-400 outline-none text-white placeholder-gray-300"
                        placeholder="Enter crop name (e.g. Wheat)"
                    >
            
                    <button 
                        id="aiBtn"
                        class="bg-yellow-400 text-black px-5 py-2 rounded-lg font-semibold hover:scale-105 transition shadow"
                        type="button" 
                        onclick="getAIPrice()"
                    >
                        Predict
                    </button>
            
                </div>
            
                <!-- Result Box -->
                <div id="aiResult" class="bg-white/10 backdrop-blur p-4 rounded-xl text-center min-h-[60px] flex items-center justify-center">
                    <span class="text-gray-300">AI result will appear here</span>
                </div>
            
            </div>



        </div>




        <div class="w-full lg:w-80 space-y-6   ">


            <div class="bg-white p-6 rounded-xl shadow text-center shadow-lg">

                <img src="https://i.pravatar.cc/40" class="w-20 h-20 rounded-full mx-auto" />

                <h2 class="mt-3 font-semibold">
                    <%= user.username %>
                </h2>

                <p class="text-gray-500 text-sm">
                    <%= user.location %>
                </p>

                <p class="text-gray-500 text-sm">
                    <%= user.contact %>
                </p>

                <button class="mt-4 bg-green-600 text-white px-4 py-2 rounded-lg">
                    Edit Profile
                </button>

            </div>


            <div class="bg-amber-300 p-6 rounded-xl shadow-lg">

                <h3 class="font-semibold mb-3">
                    Farmer Stats
                </h3>

                <p class="text-gray-600">
                    Member Since: Jan 2024
                </p>

                <p class="text-gray-600">
                    Total Deals: 28
                </p>

                <p class="text-gray-600">
                    Rating: 4.6
                </p>

                <p class="text-green-600 font-medium mt-2">
                    Verified Farmer
                </p>
                <div class="flex justify-end items-center"><a
                        class="mt-4 font-bold bg-gray-50 border-[1px] border-red-600 text-red-600 px-4 py-2 rounded-lg "
                        href="/logout">log out</a></div>


            </div>

        </div>

    </div>

</body>

<script>
    async function getAIPrice() {
        const cropName = document.querySelector('input[name="cropName"]').value;

        const resultDiv = document.getElementById("aiResult");
        resultDiv.innerText = "Getting AI prediction...";

        try {
            const res = await fetch("/predict-price", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({ cropName })
            });

            const data = await res.json();

            resultDiv.innerHTML = `
            <div>Price: ₹${data.predicted_price}</div>
        `;

        } catch (err) {
            resultDiv.innerText = "Failed to fetch AI data";
        }
    }
</script>

</html>