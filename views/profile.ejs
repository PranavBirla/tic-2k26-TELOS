<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Krishiq | Farmer Dashboard</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&family=DM+Sans:wght@400;500&display=swap"
        rel="stylesheet">

    <style>
        body {
            font-family: 'DM Sans', sans-serif;
            background: #F9FAFB;
        }

        h1,
        h2,
        h3 {
            font-family: 'Sora', sans-serif;
        }
    </style>

</head>

<body>

    <header
    class="bg-white shadow-2xl rounded-full m-10 w-11/12 md:w-9/12 mx-auto border-b border-gray-200 px-3 md:px-10 py-4 flex justify-between items-center">

    <h1 class="text-green-700 font-semibold text-lg">KRISHIQ</h1>

            <div class="flex items-center space-x-6">

                <a href="/mylistings" class="text-gray-600 hover:text-green-600">
                    My Listings
                </a>

                <a href="/farmerdeals" class="text-gray-600 hover:text-green-600">
                    Deals
                </a>

      <div class="relative">
        <img src="https://i.pravatar.cc/40" class="w-10 h-10 rounded-full cursor-pointer border-2 border-gray-300">
      </div>
    </nav>

  </header>




    <div class="max-w-7xl mx-auto px-6 mt-8 flex flex-col lg:flex-row gap-6">




        <div class="flex-1 space-y-6">




            <div class="grid grid-cols-2 gap-4 lg:flex ">

                <div class="bg-white p-6 rounded-xl shadow-lg lg:w-1/4">
                    <p class="text-gray-500 text-sm">My Listings</p>
                    <p class="text-3xl font-bold text-gray-700">8</p>
                </div>

                <div class="bg-white p-6 rounded-xl shadow-lg lg:w-1/4">
                    <p class="text-gray-500 text-sm">Active Deals</p>
                    <p class="text-3xl font-bold text-gray-700">3</p>
                </div>

                <div class="bg-white p-6 rounded-xl shadow-lg lg:w-1/4">
                    <p class="text-gray-500 text-sm">Completed Deals</p>
                    <p class="text-3xl font-bold text-gray-700">12</p>
                </div>

                <div class="bg-white p-6 rounded-xl shadow-lg lg:w-1/4">
                    <p class="text-gray-500 text-sm">Revenue This Month</p>
                    <p class="text-3xl font-bold text-gray-600">₹18,500</p>
                </div>

            </div>


            <div class="bg-white p-6 rounded-xl shadow-lg lg:w-full">

                <h2 class="text-lg font-semibold mb-4">
                    Quick Actions
                </h2>

                <div class="flex flex-wrap gap-4 lg:justify-center  ">

                    <a class="bg-green-500 text-white
                    p px-5 py-2 rounded-lg hover:bg-green-600" href="/addcrop">
                        Add Listing
                    </a>

                    <a class="bg-green-500 text-white
                    px-5 py-2 rounded-lg hover:bg-green-600" href="/mylistings">
                        View Listing
                    </a>

                    <a class="bg-green-500 text-white
                    p px-5 py-2 rounded-lg hover:bg-green-600" href="/farmerdeals">
                        Check Deals
                    </a>


                </div>

            </div>



            <div class="bg-gradient-to-r font-stretch-50% from-blue-800 via-indigo-900 to-pink-500 p-6 min-h-[47%] rounded-xl shadow-lg">
                <div class="flex gap-2 items-center">
                    <h1 class="text-white text-5xl font-bold">AI</h1> <h2 class="text-3xl text-white items-center">Features</h2>
                </div>

            <div>

            </div>
            </div>



        </div>




        <div class="w-full lg:w-80 space-y-6   ">


            <div class="bg-white p-6 rounded-xl shadow text-center shadow-lg">

                <img src="https://i.pravatar.cc/40" class="w-20 h-20 rounded-full mx-auto" />

                <h2 class="mt-3 font-semibold">
                    <%= user.username %>
                </h2>

                <p class="text-gray-500 text-sm">
                    <%= user.location %>
                </p>

                <p class="text-gray-500 text-sm">
                    <%= user.contact %>
                </p>

                <button class="mt-4 bg-green-600 text-white px-4 py-2 rounded-lg">
                    Edit Profile
                </button>

            </div>


            <div class="bg-amber-300 p-6 rounded-xl shadow-lg">

                <h3 class="font-semibold mb-3">
                    Farmer Stats
                </h3>

                <p class="text-gray-600">
                    Member Since: Jan 2024
                </p>

                <p class="text-gray-600">
                    Total Deals: 28
                </p>

                <p class="text-gray-600">
                    Rating: 4.6
                </p>

                <p class="text-green-600 font-medium mt-2">
                    Verified Farmer
                </p>
                <div class="flex justify-end items-center"><a
                        class="mt-4 font-bold bg-gray-50 border-[1px] border-red-600 text-red-600 px-4 py-2 rounded-lg "
                        href="/logout">log out</a></div>


            </div>

        </div>

    </div>

</body>

</html>