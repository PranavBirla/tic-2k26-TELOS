<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Crop Details | KRISHIQ</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        html{
            scroll-behavior: smooth;
        }
    </style>

</head>

<body class="bg-gray-50 text-gray-800">


    <header class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-gray-200">

        <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">


            <div class="flex items-center gap-3">

                <span class="text-lg font-semibold text-green-700">
                    KRISHIQ
                </span>
            </div>


            <div class="hidden md:flex w-[420px]">
                <input type="text" placeholder="Search crops, farmers..."
                    class="w-full bg-gray-100 border border-gray-200 rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-green-500 outline-none">
            </div>

            <!-- NAV LINKS -->
            <div class="flex items-center gap-4 text-sm">

                <a href="/marketplace" class="text-gray-600 hover:text-green-700">
                    Marketplace
                </a>

                <a href="/buyerdeals" class="text-gray-600 hover:text-green-700">
                    Deals
                </a>

                <div class="relative">
                    <img src="https://i.pravatar.cc/40"
                        class="w-10 h-10 rounded-full cursor-pointer border-2 border-gray-300">
                </div>

            </div>

        </div>

    </header>


    <div class="max-w-7xl mx-auto px-6 py-10 grid lg:grid-cols-2 gap-12">


        <div>


            <div class="overflow-hidden rounded-xl shadow-lg">
                <img id="mainImage"
                    src="https://img.freepik.com/premium-photo/wheat-grain-spills-out-burlap-black-background_206268-10615.jpg"
                    class="w-full h-[420px] object-cover transition duration-500 hover:scale-105">
            </div>


            <div class="grid grid-cols-4 gap-4 mt-4">


                <img src="https://img.freepik.com/premium-photo/wheat-grain-spills-out-burlap-black-background_206268-10615.jpg"
                    onclick="changeImage(this)"
                    class="thumb h-24 w-full object-cover rounded-lg cursor-pointer border-2  border-green-500  hover:scale-105 transition">


                <img src="https://images.unsplash.com/photo-1574323347407-f5e1ad6d020b?auto=format&fit=crop&w=900&q=80"
                    onclick="changeImage(this)"
                    class="thumb h-24 w-full object-cover rounded-lg cursor-pointer border-2 border-transparent hover:scale-105 transition">


                <img src="https://m.media-amazon.com/images/I/812MAscsndL._AC_UF894,1000_QL80_.jpg"
                    onclick="changeImage(this)"
                    class="thumb h-24 w-full object-cover rounded-lg cursor-pointer border-2 border-transparent hover:scale-105 transition">

            </div>

            <form id="Negotiation" action="/deal/<%= crop._id %>" method="POST">


                <div class="mt-8 bg-yellow-50 border border-yellow-200 rounded-xl p-6 shadow-sm hidden lg:block">

                    <h3 class="text-lg font-semibold text-yellow-800 mb-4">
                        Negotiate This Deal
                    </h3>

                    <div class="mb-4">
                        <label class="text-sm text-gray-600">
                            Price per Kg
                        </label>

                        <input id="price-desktop" type="number" placeholder="Enter your price"
                            class="w-full mt-1 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-yellow-400 outline-none bg-white">
                    </div>

                    <div class="mb-4">
                        <label class="text-sm text-gray-600">
                            Quantity
                        </label>

                        <div class="flex gap-2 mt-1">

                            <input id="qty-desktop" type="number" placeholder="Amount"
                                class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-yellow-400 outline-none bg-white">

                            <select id="unit-desktop"
                                class="px-3 py-2 border rounded-lg focus:ring-2 focus:ring-yellow-400 outline-none bg-white">

                                <option value="kg">Kg</option>
                                <option value="quintal">Quintal</option>

                            </select>

                        </div>

                    </div>

                    <div class="flex justify-between items-center bg-white border rounded-lg p-3 mb-4">

                        <span class="text-sm text-gray-600">
                            Negotiated price
                        </span>

                        <span id="total-desktop" class="font-semibold text-yellow-700">
                            ₹ 0
                        </span>

                    </div>

                    <button
                        class="w-full bg-yellow-500 hover:bg-yellow-600 text-white font-semibold py-3 rounded-lg transition shadow">

                        Send Deal to Farmer

                    </button>

                    <p class="text-xs text-gray-500 mt-3 text-center">
                        Farmer will review and respond to your offer
                    </p>

                </div>

            </form>
        </div>


        <div>

            <span class="bg-green-100 text-green-700 text-xs px-3 py-1 rounded-full font-medium">
                Organic Certified
            </span>

            <h1 class="text-3xl font-bold mt-3">
                <%= crop.cropName %>
            </h1>


            <div class="mt-6 bg-white border rounded-xl p-5 shadow-sm flex justify-between items-center">

                <div>

                    <p class="text-sm text-gray-500">
                        Crop Price
                    </p>

                    <p class="text-2xl font-bold text-green-700">
                        <%= crop.price %> ₹ / Kg
                    </p>

                    <p class="text-sm text-gray-500 mt-1">
                        12 km away
                    </p>

                </div>

                <button class="bg-green-600 hover:bg-green-700 text-white px-6 py-3 rounded-lg font-semibold shadow">
                    Make a Deal
                </button>

            </div>


            <div class="grid grid-cols-2 gap-4 mt-6">

                <div class="bg-white border rounded-xl p-4 shadow-sm">
                    <p class="text-xs text-gray-500">
                        Available Stock
                    </p>
                    <p class="text-lg font-semibold">
                        <%= crop.quantity %> Kg
                    </p>
                </div>

                <div class="  flex items-center justify-center">

                    <a  href="#Negotiation"
                        class=" flex justify-center bg-yellow-500 hover:bg-yellow-600 w-full text-white px-6 py-3 rounded-lg font-semibold shadow">
                        Negotiate
                    </a>

                </div>

            </div>


            <h3 class="font-semibold mt-8 mb-2">
                Description
            </h3>

            <p class="text-gray-600 text-sm leading-relaxed">
                Hand-harvested from the fertile plains of Punjab. This Sharbati Wheat is known for its high protein
                content and golden texture. No chemical pesticides were used during the 120-day growth cycle.
            </p>


            <h3 class="font-semibold mt-8 mb-4">
                About Farmer
            </h3>

            <div class="bg-white border rounded-xl p-5 flex gap-4 shadow-sm">

                <div
                    class="w-12 h-12 rounded-full bg-green-600 text-white flex items-center justify-center font-semibold">
                    RK
                </div>

                <div>

                    <p class="font-semibold">
                        Rajesh Kumar
                    </p>

                    <p class="text-sm text-gray-500">
                        Sangrur, Punjab
                    </p>

                    <p class="text-sm text-yellow-500 mt-1">
                        4.8 Farmer Rating
                    </p>

                    <p class="text-sm text-gray-600 mt-2 italic">
                        "I've been farming this land for 20 years. This wheat batch is the best of this season."
                    </p>

                </div>

            </div>


            <h3 class="font-semibold mt-8 mb-3">
                Crop Details
            </h3>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">

                <div class="bg-white border rounded-lg p-4 shadow-sm">
                    <p class="text-gray-500">
                        Listed On
                    </p>
                    <p class="font-semibold">
                        20 March 2026
                    </p>
                </div>

                <div class="bg-white border rounded-lg p-4 shadow-sm">
                    <p class="text-gray-500">
                        Harvest Date
                    </p>
                    <p class="font-semibold">
                        10 March 2026
                    </p>
                </div>

                <div class="bg-white border rounded-lg p-4 shadow-sm">
                    <p class="text-gray-500">
                        Farmer Rating
                    </p>
                    <p class="font-semibold">
                        4.8 / 5
                    </p>
                </div>

                <div class="bg-white border rounded-lg p-4 shadow-sm">
                    <p class="text-gray-500">
                        Contact
                    </p>
                    <p class="font-semibold">
                        +91 98765 43210
                    </p>
                </div>

            </div>

        </div>

    </div>
    <div class="lg:hidden">
        <div class="mt-8 bg-yellow-50 border border-yellow-200 rounded-xl p-6 shadow-sm ">

            <h3 class="text-lg font-semibold text-yellow-800 mb-4">
                Negotiate This Deal
            </h3>

            <div class="mb-4">
                <label class="text-sm text-gray-600">
                    Price per Kg
                </label>

                <input id="price-mobile" type="number" placeholder="Enter your price"
                    class="w-full mt-1 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-yellow-400 outline-none bg-white">
            </div>

            <div class="mb-4">
                <label class="text-sm text-gray-600">
                    Quantity
                </label>

                <div class="flex gap-2 mt-1">

                    <input id="qty-mobile" type="number" placeholder="Amount"
                        class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-yellow-400 outline-none bg-white">

                    <select id="unit-mobile"
                        class="px-3 py-2 border rounded-lg focus:ring-2 focus:ring-yellow-400 outline-none bg-white">

                        <option value="kg">Kg</option>
                        <option value="quintal">Quintal</option>

                    </select>

                </div>

            </div>

            <div class="flex justify-between items-center bg-white border rounded-lg p-3 mb-4">

                <span class="text-sm text-gray-600">
                    Negotiated price
                </span>

                <span id="total-mobile" class="font-semibold text-yellow-700">
                    ₹ 0
                </span>

            </div>

            <button
                class="w-full bg-yellow-500 hover:bg-yellow-600 text-white font-semibold py-3 rounded-lg transition shadow">

                Send Deal to Farmer

            </button>

            <p class="text-xs text-gray-500 mt-3 text-center">
                Farmer will review and respond to your offer
            </p>

        </div>
    </div>

    <script>

        function changeImage(element) {

            const mainImage = document.getElementById("mainImage")

            mainImage.src = element.src

            document.querySelectorAll(".thumb").forEach(img => {
                img.classList.remove("border-green-500")
                img.classList.add("border-transparent")
            })

            element.classList.remove("border-transparent")
            element.classList.add("border-green-500")

        }

    </script>

    <script>
        function makeCalculator(priceId, qtyId, unitId, totalId) {
            const p = document.getElementById(priceId)
            const q = document.getElementById(qtyId)
            const u = document.getElementById(unitId)
            const t = document.getElementById(totalId)
            if (!p || !q || !u || !t) return
            function calc() {
                let pv = parseFloat(p.value) || 0
                let qv = parseFloat(q.value) || 0
                if (u.value === "quintal") qv *= 100
                t.innerText = "₹ " + (pv * qv)
            }
            p.addEventListener("input", calc)
            q.addEventListener("input", calc)
            u.addEventListener("change", calc)
        }

        makeCalculator("price-desktop", "qty-desktop", "unit-desktop", "total-desktop")
        makeCalculator("price-mobile", "qty-mobile", "unit-mobile", "total-mobile")
    </script>

</body>

</html>