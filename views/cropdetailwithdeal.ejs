<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Crop Details | KRISHIQ</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        
        html {
            scroll-behavior: smooth;
        }
    </style>

</head>

<body class="bg-gray-200 text-gray-800">


    <nav
        class="items-center flex  m-10 top-5 my-5 rounded-full bg-white w-9/12 mx-auto z-50 navbar-blur  border-b border-[#E5E7EB] shadow-2xl">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">


                <a href="/" class="flex items-center gap-2.5 group">
                    <div class="w-8 h-8 logo-dot rounded-lg flex items-center justify-center shadow-sm">
                        <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                            <path
                                d="M17 8C8 10 5.9 16.17 3.82 21C7.3 18 13.62 16 17 8zM21 3c-3.81 4-9.12 5-13 6-1.84.48-3.42 1.32-4.79 2.37A11.53 11.53 0 0 0 2.5 14c1.62-1.08 3.48-1.81 5.5-2a18.94 18.94 0 0 1 7 1.06C17.41 14.5 19.5 16.36 20 19c1.1-2.5 1.5-5 .78-7.5.41-.36.82-.74 1.22-1.13V3z" />
                        </svg>
                    </div>
                    <span class="font-heading font-semibold text-lg text-[#111827] tracking-tight">
                        Krishi<span class="text-[#16A34A]">q</span>
                    </span>
                </a>


                <div class="hidden md:flex items-center gap-1">
                    <a href="/listings"
                        class="flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium text-[#6B7280] hover:text-[#16A34A] hover:bg-[#DCFCE7] transition-colors duration-150">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                        </svg>
                        My Listings
                    </a>
                    <a href="/deals"
                        class="flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium text-[#16A34A] bg-[#DCFCE7] transition-colors duration-150">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                        </svg>
                        Deals
                    </a>
                    <a href="/marketplace"
                        class="flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium text-[#6B7280] hover:text-[#16A34A] hover:bg-[#DCFCE7] transition-colors duration-150">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                        </svg>
                        Marketplace
                    </a>
                </div>


                <div class="flex items-center gap-3">
                    <button
                        class="relative p-2 rounded-lg text-[#6B7280] hover:text-[#16A34A] hover:bg-[#DCFCE7] transition-colors duration-150">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                        </svg>
                        <span
                            class="absolute top-1.5 right-1.5 w-2 h-2 bg-[#EF4444] rounded-full border-2 border-white"></span>
                    </button>
                    <a href="/profile" class="flex items-center gap-2 group">
                        <div class="w-9 h-9 rounded-full overflow-hidden avatar-ring">
                            <img src="https://ui-avatars.com/api/?name=Ramesh+Kumar&background=16A34A&color=fff&size=80"
                                alt="Ramesh Kumar" class="w-full h-full object-cover" />
                        </div>
                        <span
                            class="hidden sm:block text-sm font-medium text-[#111827] group-hover:text-[#16A34A] transition-colors duration-150">Ramesh</span>
                    </a>
                 
                    <button
                        class="md:hidden p-2 rounded-lg text-[#6B7280] hover:bg-[#F9FAFB] transition-colors duration-150">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                    </button>
                </div>

            </div>
        </div>
    </nav>



    <div class="max-w-7xl mx-auto px-6 py-10 grid lg:grid-cols-2 gap-12">


        <div>


            <div class="overflow-hidden rounded-xl shadow-lg">
                <img id="mainImage" src="https://img.freepik.com/premium-photo/wheat-grain-spills-out-burlap-black-background_206268-10615.jpg" class="w-full h-[420px] object-cover transition duration-500 hover:scale-105">
            </div>


            <div class="grid grid-cols-4 gap-4 mt-4">


                <img src="https://img.freepik.com/premium-photo/wheat-grain-spills-out-burlap-black-background_206268-10615.jpg" onclick="changeImage(this)" class="thumb h-24 w-full object-cover rounded-lg cursor-pointer border-2  border-green-500  hover:scale-105 transition">


                <img src="https://images.unsplash.com/photo-1574323347407-f5e1ad6d020b?auto=format&fit=crop&w=900&q=80" onclick="changeImage(this)" class="thumb h-24 w-full object-cover rounded-lg cursor-pointer border-2 border-transparent hover:scale-105 transition">


                <img src="https://m.media-amazon.com/images/I/812MAscsndL._AC_UF894,1000_QL80_.jpg" onclick="changeImage(this)" class="thumb h-24 w-full object-cover rounded-lg cursor-pointer border-2 border-transparent hover:scale-105 transition">

            </div>

            <form id="Negotiation" action="/deal/<%= crop._id %>" method="POST">


                <div class="mt-8 bg-yellow-50 border border-yellow-200 rounded-xl p-6 shadow-sm hidden lg:block">

                    <h3 class="text-lg font-semibold text-yellow-800 mb-4">
                        Negotiate This Deal
                    </h3>

                    <div class="mb-4">
                        <label class="text-sm name='offeredPrice' text-gray-600">
                            Price per Kg
                        </label>

                        <input id="price-desktop" type="number" name="offeredPrice" placeholder="Enter your price" class="w-full mt-1 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-yellow-400 outline-none bg-white" required>
                    </div>

                    <div class="mb-4">
                        <label class="text-sm text-gray-600">
                            Quantity
                        </label>

                        <div class="flex gap-2 mt-1">

                            <input id="qty-desktop" type="number" name="negotiatedQuantity" required placeholder="Amount" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-yellow-400 outline-none bg-white">

                            <select id="unit-desktop" class="px-3 py-2 border rounded-lg focus:ring-2 focus:ring-yellow-400 outline-none bg-white">

                                <option value="kg">Kg</option>
                                <option value="quintal">Quintal</option>

                            </select>

                        </div>

                    </div>

                    <div class="flex justify-between items-center bg-white border rounded-lg p-3 mb-4">

                        <span class="text-sm text-gray-600">
                            Negotiated price
                        </span>

                        <span id="total-desktop" class="font-semibold text-yellow-700">
                            ₹ 0
                        </span>

                    </div>

                    <button class="w-full bg-yellow-500 hover:bg-yellow-600 text-white font-semibold py-3 rounded-lg transition shadow">

                        Send Deal to Farmer

                    </button>

                    <p class="text-xs text-gray-500 mt-3 text-center">
                        Farmer will review and respond to your offer
                    </p>

                </div>

            </form>
        </div>


        <div>

            <span class="bg-green-100 text-green-700 text-xs px-3 py-1 rounded-full font-medium">
                Organic Certified
            </span>

            <h1 class="text-3xl font-bold mt-3">
                <%= crop.cropName %>
            </h1>


            <div class="mt-6 bg-white border rounded-xl p-5 shadow-sm flex justify-between items-center">

                <div>

                    <p class="text-sm text-gray-500">
                        Crop Price
                    </p>

                    <p class="text-2xl font-bold text-green-700">
                        <%= crop.price %> ₹ / Kg
                    </p>

                    <p class="text-sm text-gray-500 mt-1">
                        12 km away
                    </p>

                </div>

                <form action="/deal/direct/<%= crop._id %>" method="POST" onsubmit="return confirmDeal('Do you really want to make this Deal!')">
                    <button class="bg-green-600 text-white px-4 py-2 rounded-xl">
     Make Deal
  </button>
                </form>

            </div>


            <div class="grid grid-cols-2 gap-4 mt-6">

                <div class="bg-white border rounded-xl p-4 shadow-sm">
                    <p class="text-xs text-gray-500">
                        Available Stock
                    </p>
                    <p class="text-lg font-semibold">
                        <%= crop.quantity %> Kg
                    </p>
                </div>

                <div class="  flex items-center justify-center">

                    <a href="#Negotiation" class=" flex justify-center bg-yellow-500 hover:bg-yellow-600 w-full text-white px-6 py-3 rounded-lg font-semibold shadow">
                        Negotiate
                    </a>

                </div>

            </div>


            <h3 class="font-semibold mt-8 mb-2">
                Description
            </h3>

            <p class="text-gray-600 text-sm leading-relaxed">
                Hand-harvested from the fertile plains of Punjab. This Sharbati Wheat is known for its high protein content and golden texture. No chemical pesticides were used during the 120-day growth cycle.
            </p>


            <h3 class="font-semibold mt-8 mb-4">
                About Farmer
            </h3>

            <div class="bg-white border rounded-xl p-5 flex gap-4 shadow-sm">

                <div class="w-12 h-12 rounded-full bg-green-600 text-white flex items-center justify-center font-semibold">
                    RK
                </div>

                <div>

                    <p class="font-semibold">
                        Rajesh Kumar
                    </p>

                    <p class="text-sm text-gray-500">
                        Sangrur, Punjab
                    </p>

                    <p class="text-sm text-yellow-500 mt-1">
                        4.8 Farmer Rating
                    </p>

                    <p class="text-sm text-gray-600 mt-2 italic">
                        "I've been farming this land for 20 years. This wheat batch is the best of this season."
                    </p>

                </div>

            </div>


            <h3 class="font-semibold mt-8 mb-3">
                Crop Details
            </h3>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">

                <div class="bg-white border rounded-lg p-4 shadow-sm">
                    <p class="text-gray-500">
                        Listed On
                    </p>
                    <p class="font-semibold">
                        20 March 2026
                    </p>
                </div>

                <div class="bg-white border rounded-lg p-4 shadow-sm">
                    <p class="text-gray-500">
                        Harvest Date
                    </p>
                    <p class="font-semibold">
                        10 March 2026
                    </p>
                </div>

                <div class="bg-white border rounded-lg p-4 shadow-sm">
                    <p class="text-gray-500">
                        Farmer Rating
                    </p>
                    <p class="font-semibold">
                        4.8 / 5
                    </p>
                </div>

                <div class="bg-white border rounded-lg p-4 shadow-sm">
                    <p class="text-gray-500">
                        Contact
                    </p>
                    <p class="font-semibold">
                        +91 98765 43210
                    </p>
                </div>

            </div>

        </div>

    </div>
    <div class="lg:hidden">
        <div class="mt-8 bg-yellow-50 border border-yellow-200 rounded-xl p-6 shadow-sm ">

            <h3 class="text-lg font-semibold text-yellow-800 mb-4">
                Negotiate This Deal
            </h3>

            <div class="mb-4">
                <label class="text-sm text-gray-600">
                    Price per Kg
                </label>

                <input id="price-mobile" type="number" placeholder="Enter your price" class="w-full mt-1 px-4 py-2 border rounded-lg focus:ring-2 focus:ring-yellow-400 outline-none bg-white">
            </div>

            <div class="mb-4">
                <label class="text-sm text-gray-600">
                    Quantity
                </label>

                <div class="flex gap-2 mt-1">

                    <input id="qty-mobile" type="number" placeholder="Amount" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-yellow-400 outline-none bg-white">

                    <select id="unit-mobile" class="px-3 py-2 border rounded-lg focus:ring-2 focus:ring-yellow-400 outline-none bg-white">

                        <option value="kg">Kg</option>
                        <option value="quintal">Quintal</option>

                    </select>

                </div>

            </div>

            <div class="flex justify-between items-center bg-white border rounded-lg p-3 mb-4">

                <span class="text-sm text-gray-600">
                    Negotiated price
                </span>

                <span id="total-mobile" class="font-semibold text-yellow-700">
                    ₹ 0
                </span>

            </div>

            <button class="w-full bg-yellow-500 hover:bg-yellow-600 text-white font-semibold py-3 rounded-lg transition shadow">

                Send Deal to Farmer

            </button>

            <p class="text-xs text-gray-500 mt-3 text-center">
                Farmer will review and respond to your offer
            </p>

        </div>
    </div>

    <script>
        function changeImage(element) {

            const mainImage = document.getElementById("mainImage")

            mainImage.src = element.src

            document.querySelectorAll(".thumb").forEach(img => {
                img.classList.remove("border-green-500")
                img.classList.add("border-transparent")
            })

            element.classList.remove("border-transparent")
            element.classList.add("border-green-500")

        }
    </script>

    <script>



  function confirmDelete() {
    return confirm("Are you sure you want to delete this crop?");
  }
    

        function makeCalculator(priceId, qtyId, unitId, totalId) {
            const p = document.getElementById(priceId)
            const q = document.getElementById(qtyId)
            const u = document.getElementById(unitId)
            const t = document.getElementById(totalId)
            if (!p || !q || !u || !t) return

            function calc() {
                let pv = parseFloat(p.value) || 0
                let qv = parseFloat(q.value) || 0
                if (u.value === "quintal") qv *= 100
                t.innerText = "₹ " + (pv * qv)
            }
            p.addEventListener("input", calc)
            q.addEventListener("input", calc)
            u.addEventListener("change", calc)
        }

        makeCalculator("price-desktop", "qty-desktop", "unit-desktop", "total-desktop")
        makeCalculator("price-mobile", "qty-mobile", "unit-mobile", "total-mobile")
    </script>

</body>

</html>