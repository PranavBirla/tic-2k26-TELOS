<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Krishiq Sign Up</title>

<script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-gray-100 min-h-screen flex">

<!-- Left Side Farmer Image -->
<div class="hidden md:block w-1/2 h-screen">
<img src="images/kisan.png"
class="w-full h-full object-cover"
alt="Farmer">
</div>

<!-- Right Side Signup Section -->
<div class="w-full md:w-1/2 flex items-center justify-center relative">

<div class="absolute top-6 right-6 text-sm">
  Already have an account?
  <a href="http://localhost:3000/login#" class="font-medium hover:underline">Log in</a>
</div>

<div class="bg-white p-8 rounded-xl shadow-lg w-full max-w-md 
transform transition-all duration-300 hover:scale-95 hover:shadow-2xl">
<div class="flex items-center gap-2 mb-6">
    <div class="w-10 h-10 rounded-full overflow-hidden">
        <img src="images/logo.png"
             alt="Krishiq Logo"
             class="w-full h-full object-cover scale-125">
    </div>
    <h1 class="text-xl text-green-700 font-bold">Krishiq</h1>
</div>

<h2 class="text-2xl font-semibold mb-6">Sign up</h2>

<form id="signupForm" action="/signup" method="POST" class="space-y-4">

<!-- Full Name -->
<input type="text" name="username" placeholder="Full name"
class="w-full border rounded-md p-2 focus:outline-none focus:ring-1 focus:ring-green-500">

<!-- Email -->
<input type="email" name="email" placeholder="Email"
class="w-full border rounded-md p-2 focus:outline-none focus:ring-1 focus:ring-green-500">

<!-- Password -->
<input type="password" name="password" placeholder="Password"
class="w-full border rounded-md p-2 focus:outline-none focus:ring-1 focus:ring-green-500">

<!-- Phone + Location -->
<div class="flex gap-4">

<input type="text" name="contact" placeholder="+91 XXXXXXXXXX"
class="w-1/2 border rounded-md p-2 focus:outline-none focus:ring-1 focus:ring-green-500">

<input list="locations" name="location" placeholder="Location"
class="w-1/2 border rounded-md p-2 text-black focus:outline-none focus:ring-1 focus:ring-green-500">

<datalist id="locations">

<!-- Madhya Pradesh -->
<option value="Bhopal, Madhya Pradesh">
<option value="Indore, Madhya Pradesh">
<option value="Jabalpur, Madhya Pradesh">
<option value="Gwalior, Madhya Pradesh">
<option value="Ujjain, Madhya Pradesh">

<!-- Maharashtra -->
<option value="Mumbai, Maharashtra">
<option value="Pune, Maharashtra">
<option value="Nagpur, Maharashtra">
<option value="Nashik, Maharashtra">

<!-- Uttar Pradesh -->
<option value="Lucknow, Uttar Pradesh">
<option value="Kanpur, Uttar Pradesh">
<option value="Varanasi, Uttar Pradesh">
<option value="Agra, Uttar Pradesh">

<!-- Rajasthan -->
<option value="Jaipur, Rajasthan">
<option value="Udaipur, Rajasthan">
<option value="Jodhpur, Rajasthan">
<option value="Kota, Rajasthan">

<!-- Gujarat -->
<option value="Ahmedabad, Gujarat">
<option value="Surat, Gujarat">
<option value="Vadodara, Gujarat">


<option value="Bangalore, Karnataka">
<option value="Mysore, Karnataka">


<option value="Chennai, Tamil Nadu">
<option value="Coimbatore, Tamil Nadu">
<option value="Madurai, Tamil Nadu">

</datalist>

</div>


<div>
<label class="block mb-2 font-medium">Register as</label>

<div class="flex gap-6">

<label class="flex items-center gap-2">
<input type="radio" name="role" value="farmer" >
Farmer
</label>

<label class="flex items-center gap-2">
<input type="radio" name="role" value="buyer" >
Buyer
</label>

</div>
</div>


<button
type="submit"
class="w-full bg-green-600 text-white py-2 rounded-md hover:bg-green-700 transition">
Create account
</button>

</form>

</div>
</div>

