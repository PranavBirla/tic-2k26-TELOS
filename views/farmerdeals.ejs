<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Krishiq | My Deals</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              green: '#16A34A',
              greenDark: '#15803D',
              greenLight: '#DCFCE7',
              yellow: '#FACC15',
              yellowLight: '#FEF9C3',
            }
          },
          fontFamily: {
            heading: ['Sora', 'sans-serif'],
            body: ['DM Sans', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <style>
    * { box-sizing: border-box; }
    body { font-family: 'DM Sans', sans-serif; background-color: #F9FAFB; color: #111827; }
    .font-heading, h1, h2, h3, h4 { font-family: 'Sora', sans-serif; }

    /* Navbar blur */
    .navbar-blur { backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }

    /* Card hover */
    .deal-card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .deal-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 28px 0 rgba(22,163,74,0.09), 0 2px 8px 0 rgba(0,0,0,0.06);
    }

    .stat-card { transition: transform 0.18s ease, box-shadow 0.18s ease; }
    .stat-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px 0 rgba(22,163,74,0.09), 0 2px 6px 0 rgba(0,0,0,0.05);
    }

    /* Tab indicator */
    .tab-btn { position: relative; transition: color 0.15s ease; }
    .tab-btn.active { color: #16A34A; }
    .tab-btn.active::after {
      content: '';
      position: absolute;
      bottom: -1px;
      left: 0; right: 0;
      height: 2px;
      background: #16A34A;
      border-radius: 99px;
    }
    .tab-btn:not(.active):hover { color: #374151; }

    /* Button transitions */
    .btn-accept { transition: background 0.15s ease, transform 0.15s ease; }
    .btn-accept:hover { background: #15803D; transform: translateY(-1px); }
    .btn-accept:active { transform: translateY(0); }

    .btn-reject { transition: background 0.15s ease, transform 0.15s ease; }
    .btn-reject:hover { background: #DC2626; transform: translateY(-1px); }
    .btn-reject:active { transform: translateY(0); }

    /* Logo gradient */
    .logo-dot { background: linear-gradient(135deg, #16A34A, #4ADE80); }

    /* Hide deal sections */
    .deal-section { display: none; }
    .deal-section.active { display: block; }

    /* Tabs horizontal scroll on mobile */
    .tabs-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
    .tabs-scroll::-webkit-scrollbar { display: none; }

    /* Custom scrollbar */
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: #F9FAFB; }
    ::-webkit-scrollbar-thumb { background: #D1FAE5; border-radius: 99px; }
    ::-webkit-scrollbar-thumb:hover { background: #16A34A; }

    /* Avatar ring */
    .avatar-ring { box-shadow: 0 0 0 2px #DCFCE7, 0 0 0 4px #16A34A22; }

    /* Price comparison */
    .price-up { color: #16A34A; }
    .price-down { color: #EF4444; }
  </style>
</head>
<body class="min-h-screen bg-gray-200">

  <% const activeDeals = deals.filter(d => d.status === "accepted"); %>
  <% const pendingDeals = deals.filter(d => d.status === "pending"); %>
  <% const rejectedDeals = deals.filter(d => d.status === "rejected"); %>


  <nav class="items-center flex sticky m-10 top-5 my-5 rounded-full w-9/12 mx-auto z-50 navbar-blur bg-white/90 border-b border-[#E5E7EB] shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">


        <a href="/" class="flex items-center gap-2.5 group">
          <div class="w-8 h-8 logo-dot rounded-lg flex items-center justify-center shadow-sm">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17 8C8 10 5.9 16.17 3.82 21C7.3 18 13.62 16 17 8zM21 3c-3.81 4-9.12 5-13 6-1.84.48-3.42 1.32-4.79 2.37A11.53 11.53 0 0 0 2.5 14c1.62-1.08 3.48-1.81 5.5-2a18.94 18.94 0 0 1 7 1.06C17.41 14.5 19.5 16.36 20 19c1.1-2.5 1.5-5 .78-7.5.41-.36.82-.74 1.22-1.13V3z"/>
            </svg>
          </div>
          <span class="font-heading font-semibold text-lg text-[#111827] tracking-tight">
            Krishi<span class="text-[#16A34A]">q</span>
          </span>
        </a>

        <!-- Nav Links — Desktop -->
        <div class="hidden md:flex items-center gap-1">
          <a href="/listings" class="flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium text-[#6B7280] hover:text-[#16A34A] hover:bg-[#DCFCE7] transition-colors duration-150">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
            My Listings
          </a>
          <a href="/deals" class="flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium text-[#16A34A] bg-[#DCFCE7] transition-colors duration-150">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
            </svg>
            Deals
          </a>
          <a href="/marketplace" class="flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium text-[#6B7280] hover:text-[#16A34A] hover:bg-[#DCFCE7] transition-colors duration-150">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            Marketplace
          </a>
        </div>

        <!-- Right — Avatar & Notif -->
        <div class="flex items-center gap-3">
          <button class="relative p-2 rounded-lg text-[#6B7280] hover:text-[#16A34A] hover:bg-[#DCFCE7] transition-colors duration-150">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
            </svg>
            <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-[#EF4444] rounded-full border-2 border-white"></span>
          </button>
          <a href="/profile" class="flex items-center gap-2 group">
            <div class="w-9 h-9 rounded-full overflow-hidden avatar-ring">
              <img src="https://ui-avatars.com/api/?name=Ramesh+Kumar&background=16A34A&color=fff&size=80" alt="Ramesh Kumar" class="w-full h-full object-cover" />
            </div>
            <span class="hidden sm:block text-sm font-medium text-[#111827] group-hover:text-[#16A34A] transition-colors duration-150">Ramesh</span>
          </a>
          <!-- Mobile Hamburger -->
          <button class="md:hidden p-2 rounded-lg text-[#6B7280] hover:bg-[#F9FAFB] transition-colors duration-150">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>

      </div>
    </div>
  </nav>



  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- Page Header -->
    <div class="mb-7">
      <p class="text-xs font-medium text-[#9CA3AF] uppercase tracking-widest mb-1">Deal Management</p>
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
          <h1 class="font-heading text-2xl sm:text-3xl font-bold text-[#111827]">My Deals</h1>
          <p class="text-sm text-[#6B7280] mt-1">Review and manage all crop deal requests from buyers.</p>
        </div>
        <div class="flex items-center gap-2">
          <!-- Search -->
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[#9CA3AF]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input type="text" placeholder="Search deals…" class="pl-9 pr-4 py-2 text-sm bg-white border border-[#E5E7EB] rounded-lg text-[#111827] placeholder-[#9CA3AF] focus:outline-none focus:border-[#16A34A] focus:ring-1 focus:ring-[#16A34A] transition-colors duration-150 w-48" />
          </div>
          <!-- Sort -->
          <select class="px-3 py-2 text-sm bg-white border border-[#E5E7EB] rounded-lg text-[#6B7280] focus:outline-none focus:border-[#16A34A] focus:ring-1 focus:ring-[#16A34A] transition-colors duration-150">
            <option>Latest First</option>
            <option>Oldest First</option>
            <option>Highest Offer</option>
          </select>
        </div>
      </div>
    </div>

    

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-7">

      <!-- Active Deals -->
      <div class="stat-card bg-white rounded-xl p-5 border border-[#E5E7EB] shadow-sm flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl bg-[#DCFCE7] flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-[#16A34A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-xs font-medium text-[#6B7280] uppercase tracking-wide">Active Deals</p>
          <p class="font-heading text-2xl font-bold text-[#111827] mt-0.5"><%= activeDeals.length %></p>
        </div>
        <div class="ml-auto">
          <span class="w-2 h-2 rounded-full bg-[#16A34A] inline-block"></span>
        </div>
      </div>

      <!-- Pending Deals -->
      <div class="stat-card bg-white rounded-xl p-5 border border-[#E5E7EB] shadow-sm flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl bg-[#FEF9C3] flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-xs font-medium text-[#6B7280] uppercase tracking-wide">Pending Deals</p>
          <p class="font-heading text-2xl font-bold text-[#111827] mt-0.5"><%= pendingDeals.length %></p>
        </div>
        <div class="ml-auto">
          <span class="w-2 h-2 rounded-full bg-[#FACC15] inline-block"></span>
        </div>
      </div>

      <!-- Rejected Deals -->
      <div class="stat-card bg-white rounded-xl p-5 border border-[#E5E7EB] shadow-sm flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl bg-red-50 flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-[#EF4444]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-xs font-medium text-[#6B7280] uppercase tracking-wide">Rejected Deals</p>
          <p class="font-heading text-2xl font-bold text-[#111827] mt-0.5"><%= rejectedDeals.length %></p>
        </div>
        <div class="ml-auto">
          <span class="w-2 h-2 rounded-full bg-[#EF4444] inline-block"></span>
        </div>
      </div>

    </div>

    <div class="bg-white rounded-xl border border-[#E5E7EB] shadow-sm mb-6">
      <div class="tabs-scroll px-2">
        <div class="flex items-center gap-1 min-w-max sm:min-w-0 border-b border-[#E5E7EB]">

          <button
            onclick="switchTab('active')"
            id="tab-active"
            class="tab-btn active font-heading font-semibold text-sm px-5 py-4 whitespace-nowrap focus:outline-none"
          >
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Active Deals
              <span class="px-2 py-0.5 rounded-full text-xs bg-[#DCFCE7] text-[#16A34A] font-semibold">12</span>
            </span>
          </button>

          <button
            onclick="switchTab('pending')"
            id="tab-pending"
            class="tab-btn font-heading font-semibold text-sm px-5 py-4 whitespace-nowrap text-[#6B7280] focus:outline-none"
          >
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Pending Deals
              <span class="px-2 py-0.5 rounded-full text-xs bg-[#FEF9C3] text-yellow-700 font-semibold">5</span>
            </span>
          </button>

          <button
            onclick="switchTab('rejected')"
            id="tab-rejected"
            class="tab-btn font-heading font-semibold text-sm px-5 py-4 whitespace-nowrap text-[#6B7280] focus:outline-none"
          >
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Rejected Deals
              <span class="px-2 py-0.5 rounded-full text-xs bg-red-50 text-[#EF4444] font-semibold">3</span>
            </span>
          </button>

        </div>
      </div>

      <!-- ─────────────────────────────────────── -->
      <!-- ACTIVE DEALS SECTION                     -->
      <!-- ─────────────────────────────────────── -->
      <div id="section-active" class="deal-section active p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

          <% activeDeals.forEach(deal => { %>

<div class="deal-card bg-white rounded-xl p-5 border border-[#E5E7EB] shadow-sm">

  <div class="flex items-start justify-between mb-4">
    <div class="flex items-center gap-3">
      <div>
        <h3 class="font-heading font-bold text-sm text-[#111827]">
          <%= deal.cropId.cropName %>
        </h3>
        <p class="text-xs text-[#9CA3AF]">
          Deal ID: <%= deal._id %>
        </p>
      </div>
    </div>

    <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-semibold bg-[#DCFCE7] text-[#16A34A]">
      Accepted
    </span>
  </div>

  <div class="grid grid-cols-2 gap-3 mb-4">
    <p>Quantity: <%= deal.quantity %> kg</p>
    <p>Offered: ₹<%= deal.offeredPrice %>/kg</p>
    
  </div>

</div>

<% }) %>

         
        

      <!-- ─────────────────────────────────────── -->
      <!-- PENDING DEALS SECTION                   -->
      <!-- ─────────────────────────────────────── -->
      <div id="section-pending" class="deal-section p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

          <!-- Pending Card 1 -->
          <div class="deal-card bg-white rounded-xl p-5 border border-[#E5E7EB] shadow-sm">
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-[#DCFCE7] flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-[#16A34A]" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17 8C8 10 5.9 16.17 3.82 21C7.3 18 13.62 16 17 8zM21 3c-3.81 4-9.12 5-13 6-1.84.48-3.42 1.32-4.79 2.37A11.53 11.53 0 0 0 2.5 14c1.62-1.08 3.48-1.81 5.5-2a18.94 18.94 0 0 1 7 1.06C17.41 14.5 19.5 16.36 20 19c1.1-2.5 1.5-5 .78-7.5.41-.36.82-.74 1.22-1.13V3z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-heading font-bold text-sm text-[#111827]">Rice (Chawal)</h3>
                  <p class="text-xs text-[#9CA3AF] mt-0.5">Deal ID: #KRQ-1051</p>
                </div>
              </div>
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold bg-[#FEF9C3] text-yellow-700">
                <span class="w-1.5 h-1.5 rounded-full bg-[#FACC15]"></span>
                Pending
              </span>
            </div>
            <div class="border-t border-[#E5E7EB] my-3"></div>
            <div class="grid grid-cols-2 gap-3 mb-4">
              <div class="bg-[#F9FAFB] rounded-lg p-3">
                <p class="text-xs text-[#9CA3AF] mb-1 flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                  Buyer
                </p>
                <p class="text-sm font-semibold text-[#111827]">Mehta Grain Co.</p>
              </div>
              <div class="bg-[#F9FAFB] rounded-lg p-3">
                <p class="text-xs text-[#9CA3AF] mb-1 flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/></svg>
                  Quantity
                </p>
                <p class="text-sm font-semibold text-[#111827]">600 kg</p>
              </div>
              <div class="bg-[#F9FAFB] rounded-lg p-3">
                <p class="text-xs text-[#9CA3AF] mb-1 flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                  Your Price
                </p>
                <p class="text-sm font-semibold text-[#111827]">₹38 / kg</p>
              </div>
              <div class="bg-[#F9FAFB] rounded-lg p-3">
                <p class="text-xs text-[#9CA3AF] mb-1 flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  Offered Price
                </p>
                <p class="text-sm font-semibold price-up">₹40 / kg</p>
              </div>
            </div>
            <!-- Pending: Buyer note -->
            <div class="bg-yellow-50 border border-yellow-100 rounded-lg px-3 py-2.5 mb-4 flex items-start gap-2">
              <svg class="w-4 h-4 text-yellow-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
              <p class="text-xs text-yellow-700">"Can you deliver by April 5th? We need it urgently."</p>
            </div>
            <!-- Action Buttons -->
            <div class="flex gap-3">
              <button class="btn-accept flex-1 flex items-center justify-center gap-2 px-4 py-2.5 bg-[#16A34A] text-white text-sm font-semibold font-heading rounded-lg shadow-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Accept
