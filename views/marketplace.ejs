<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KRISHIQ Marketplace</title>

    <script src="https://cdn.tailwindcss.com"></script>

  
</head>

<body class="text-gray-800 bg-gray-100 font-sans">

    <!-- NAVBAR -->
    <nav class="bg-white shadow-2xl rounded-full w-9/12 mx-auto mt-6 px-8 py-3 flex justify-between items-center sticky top-4 z-50">

        <div class="text-xl font-bold text-green-600 tracking-tight">
            KRISHIQ
        </div>

        <div class="flex items-center gap-6 text-sm font-medium text-gray-600">
            <a href="/buyerdeals" class="hover:text-green-600 transition">Deals</a>
            <a href="/buyerprofile" class="hover:text-green-600 transition">Profile</a>

            <img src="https://i.pravatar.cc/40"
                class="w-9 h-9 rounded-full border-2 border-gray-200 cursor-pointer">
        </div>
    </nav>

    <!-- HERO -->
    <div class="max-w-6xl mx-auto px-6 py-14 text-center">

        <h1 class="text-4xl md:text-5xl font-bold mb-3 text-gray-900">
            Buy Crops Directly From Farmers
        </h1>

        <p class="text-gray-500 mb-8">
            Fair Prices • Fresh Harvest • No Middlemen
        </p>

        <div class="flex justify-center">
            <input type="text"
                placeholder="Search crops like wheat, tomatoes..."
                class="w-full max-w-xl px-6 py-4 rounded-full border border-gray-200 shadow-sm focus:outline-none focus:ring-2 focus:ring-green-400 transition">
        </div>
    </div>

    <!-- GRID -->
    <div class="max-w-7xl mx-auto px-6 pb-20">

        <div class="border-t border-gray-200 mb-8"></div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-7">

            <% crops.forEach(crop => { %>

                <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-gray-100">

                    <!-- IMAGE -->
                    <img src="https://img.freepik.com/premium-photo/wheat-grain-spills-out-burlap-black-background_206268-10615.jpg"
                        class="w-full h-44 object-cover">

                    <div class="p-5">

                        <!-- TITLE -->
                        <h3 class="text-lg font-semibold text-gray-800 mb-1">
                            <%= crop.cropName %>
                        </h3>

                        <!-- FARMER -->
                        <p class="text-sm text-gray-500 mb-3">
                            👤 Rajesh Singh
                        </p>

                        <!-- INFO -->
                        <div class="flex justify-between text-sm text-gray-500 mb-4">

                            <span>⭐ 4.8</span>
                            <span>📍 12 km</span>

                        </div>

                        <!-- PRICE -->
                        <div class="text-green-600 font-bold text-lg mb-2">
                            ₹<%= crop.price %> / Quintal
                        </div>

                        <!-- QUANTITY -->
                        <div class="text-gray-500 text-sm mb-4">
                            Quantity: <%= crop.quantity %> Kg
                        </div>

                        <!-- BUTTON -->
                        <a href="/cropdetails/<%= crop._id %>"
                            class="block text-center w-full py-2.5 rounded-lg bg-green-50 text-green-700 font-medium hover:bg-green-100 transition">
                            View Details
                        </a>

                    </div>
                </div>

            <% }) %>

        </div>
    </div>

</body>

</html>