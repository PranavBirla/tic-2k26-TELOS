<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KRISHIQ - Add Crop</title>

  <!-- Tailwind CDN -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Font -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>

<body class="bg-gray-50 text-gray-900">


<header class="bg-white border-b border-gray-200 px-10 py-4 flex justify-between items-center">
  <h1 class="text-green-700 font-semibold text-lg">KRISHIQ</h1>
  <nav class="space-x-6 text-sm text-gray-500">
    <a href="/mylistings" class="hover:text-green-700">My Listings</a>
    <a href="#" class="hover:text-green-700">Deals</a>
    <a href="/" class="hover:text-green-700">Home</a>
  </nav>
</header>


<div class="max-w-6xl mx-auto px-6 py-10">
  <h2 class="text-2xl font-semibold">Add New Crop</h2>
  <p class="text-gray-500 text-sm mt-1 mb-6">Create a professional marketplace listing</p>


  <form method="POST" action="/addcrop" class="grid md:grid-cols-3 gap-6">


    <div class="md:col-span-2 bg-white p-6 rounded-xl border border-gray-200 shadow-sm">
      <h3 class="text-sm font-semibold mb-4">Crop Information</h3>

      <div class="mb-4">
        <label class="text-xs text-gray-500">Crop Name</label>
        <input name="cropName" type="text" required
          class="w-full mt-1 px-3 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-green-500 outline-none"
          placeholder="Premium Basmati Rice">
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div>
          <label class="text-xs text-gray-500">Category</label>
          <select name="category" required
            class="w-full mt-1 px-3 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-green-500">
            <option>Grains</option>
            <option>Vegetables</option>
            <option>Fruits</option>
          </select>
        </div>

        <div>
          <label class="text-xs text-gray-500">Harvest Date</label>
          <input name="harvestDate" type="date" required
            class="w-full mt-1 px-3 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-green-500">
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div>
          <label class="text-xs text-gray-500">Price (₹)</label>
          <input name="price" type="number" required
            class="w-full mt-1 px-3 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-green-500"
            placeholder="0">
        </div>

        <div>
          <label class="text-xs text-gray-500">Quantity (kg)</label>
          <input name="quantity" type="number" required
            class="w-full mt-1 px-3 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-green-500"
            placeholder="500">
        </div>
      </div>

      <div>
        <label class="text-xs text-gray-500">Description</label>
        <textarea name="description" rows="4" required
          class="w-full mt-1 px-3 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-green-500"
          placeholder="Add crop quality, storage, etc..."></textarea>
      </div>
    </div>


    <div class="space-y-6">

      <div class="bg-white p-6 rounded-xl border border-gray-200 shadow-sm">
        <h3 class="text-sm font-semibold mb-4">Media Upload</h3>

        <label class="block border-2 border-dashed border-gray-200 rounded-lg p-6 text-center cursor-pointer hover:border-green-500">
          <input type="file" name="image" class="hidden">
          <p class="text-gray-500 text-sm">Click to upload image</p>
        </label>
      </div>

      <div class="bg-gradient-to-br from-green-600 to-green-500 text-white p-5 rounded-xl text-sm shadow">
        Listings with images and proper pricing get 3x more engagement.
      </div>

    </div>

  
    <div class="md:col-span-3 flex justify-end gap-3 mt-2">
      <button type="button" class="px-5 py-2 rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-100">Cancel</button>
      <button type="submit" class="px-5 py-2 rounded-lg bg-green-600 text-white hover:bg-green-700 shadow">
        Publish Crop
      </button>
    </div>

  </form>


</div>

</body>
</html>