<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KRISHIQ | My Listings</title>


  
  <script src="https://cdn.tailwindcss.com"></script>


  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    body { font-family: 'Inter', sans-serif; background-color: #f8fafc; }
  </style>
</head>

<body class="antialiased">



<nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
    <h1 class="text-xl font-bold text-green-700">KRISHIQ</h1>
    <a href="/addcrop" class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700">
      + Add Crop
    </a>
  </div>
</nav>


<div class="max-w-6xl mx-auto px-6 py-8">


  <div class="mb-6">
    <h2 class="text-2xl font-bold">My Listings</h2>
    <p class="text-gray-500 text-sm">Manage your crop listings</p>
  </div>


  <div class="grid grid-cols-3 gap-4 mb-8">
    <div class="bg-white p-4 rounded-xl shadow text-center">
      <h3 class="text-xl font-bold text-green-600"><%= crops.length %></h3>
      <p class="text-sm text-gray-500">Total Listings</p>
    </div>

    <div class="bg-white p-4 rounded-xl shadow text-center">
      <h3 class="text-xl font-bold text-blue-600">
        <%= crops.reduce((sum, c) => sum + c.buyers, 0) %>
      </h3>
      <p class="text-sm text-gray-500">Total Inquiries</p>
    </div>

    <div class="bg-white p-4 rounded-xl shadow text-center">
      <h3 class="text-xl font-bold text-green-700">
        ₹<%= crops.reduce((sum, c) => sum + (c.price * c.quantity), 0) %>
      </h3>
      <p class="text-sm text-gray-500">Estimated Value</p>
    </div>
  </div>

  <!-- EMPTY STATE -->
  <% if (crops.length === 0) { %>
    <p class="text-center text-gray-500 mt-10">
      No listings yet. Add your first crop 🌱
    </p>
  <% } %>

  <!-- LIST -->
  <div class="space-y-4">

    <% crops.forEach(crop => { %>

      <div class="bg-white rounded-xl shadow flex overflow-hidden <%= crop.status === 'sold' ? 'opacity-70' : '' %>">

        <!-- IMAGE -->
        <img src="<%= crop.image %>" 
             class="w-48 h-40 object-cover <%= crop.status === 'sold' ? 'grayscale' : '' %>">

        <!-- CONTENT -->
        <div class="p-4 flex-1">

          <!-- TITLE + STATUS -->
          <div class="flex justify-between items-center">
            <h3 class="text-lg font-semibold"><%= crop.cropName %></h3>

            <% if (crop.status === 'active') { %>
              <span class="px-2 py-1 bg-green-100 text-green-700 rounded text-xs font-bold">
                ACTIVE
              </span>
            <% } else { %>
              <span class="px-2 py-1 bg-red-100 text-red-600 rounded text-xs font-bold">
                SOLD
              </span>
            <% } %>
          </div>

          <!-- CATEGORY -->
          <p class="text-sm text-gray-500 mt-1">
            <%= crop.category %>
          </p>

          <!-- PRICE + QUANTITY -->
          <div class="flex gap-4 mt-2">
            <span class="text-green-600 font-bold">
              ₹<%= crop.price %>/kg
            </span>

            <span class="text-gray-500">
              <%= crop.quantity > 0 ? crop.quantity + ' kg left' : 'Sold out' %>
            </span>
          </div>

          <!-- BUYERS -->
          <p class="text-sm text-gray-500 mt-1">
            <%= crop.buyers %> buyers interested
          </p>

          <!-- ACTIONS -->
          <div class="mt-3 flex gap-2">

            <% if (crop.status === 'active') { %>

              <a href="/edit/<%= crop._id %>" 
                 class="px-3 py-1 bg-green-100 text-green-700 rounded">
                Edit
              </a>

              <a href="/buyers/<%= crop._id %>" 
                 class="px-3 py-1 bg-yellow-100 text-yellow-700 rounded">
                Buyers
              </a>

              <form action="/delete/<%= crop._id %>" method="POST">
                <button class="px-3 py-1 bg-red-100 text-red-600 rounded">
                  Delete
                </button>
              </form>

            <% } else { %>

              <a href="/relist/<%= crop._id %>" 
                 class="px-3 py-1 bg-gray-200 rounded">
                Relist
              </a>

            <% } %>

          </div>

        </div>
      </div>

    <% }) %>

  </div>

</div>

</body>
</html>